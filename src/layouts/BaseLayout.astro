---
import { execSync } from 'node:child_process';
import { ClientRouter } from 'astro:transitions';
import SEO from '@components/global/SEO.astro';
import PersistentMap from '@components/PersistentMap.astro';
import '@styles/fonts.css';
import '@styles/global.css';
import '@styles/animations.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Persistent map declaration for this page */
  mapLayout?: 'world' | 'region' | 'hidden';
  mapTargetCenter?: [number, number];
  mapTargetZoom?: number;
  mapActiveCollection?: string;
}

const {
  title,
  description,
  image,
  type,
  noindex,
  mapLayout = 'hidden',
  mapTargetCenter,
  mapTargetZoom,
  mapActiveCollection,
} = Astro.props;
const buildHash = (() => { try { return execSync('git rev-parse --short HEAD').toString().trim(); } catch { return 'unknown'; } })();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="build-id" content={buildHash} />

    <!-- Google Fonts: Vollkorn + IBM Plex Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Vollkorn:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
    />

    <!-- Umami Analytics -->
    <script
      is:inline
      defer
      src="https://analytics.heist.studio/script.js"
      data-website-id="c305a664-d222-41eb-937a-8309bf7208f0"
      data-domains="heist.studio"
    ></script>

    <!-- Umami Kit: time-on-page heartbeat + scroll depth -->
    <script is:inline defer src="/scripts/umami-kit.js"></script>

    <ClientRouter />

    <!-- Inline theme script to prevent flash -->
    <script is:inline>
      (function () {
        function applyTheme() {
          var stored = localStorage.getItem('theme');
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: light)').matches
              ? 'light'
              : 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- Inline rail-width script to prevent layout flash -->
    <script is:inline>
      (function () {
        function applyRailWidth() {
          if (window.innerWidth >= 1024) {
            var stored = localStorage.getItem('rail-collapsed');
            if (stored !== null) {
              document.documentElement.style.setProperty(
                '--rail-width',
                stored === '1' ? '52px' : '180px'
              );
            }
            /* If no stored preference, let CSS fallback handle it:
               PageLayout defaults to 180px, ProjectLayout to 52px */
          } else {
            document.documentElement.style.removeProperty('--rail-width');
          }
        }
        applyRailWidth();
        document.addEventListener('astro:after-swap', applyRailWidth);
      })();
    </script>
  </head>
  <body
    data-map-layout={mapLayout}
    data-map-target-center={mapTargetCenter ? JSON.stringify(mapTargetCenter) : undefined}
    data-map-target-zoom={mapTargetZoom !== undefined ? String(mapTargetZoom) : undefined}
    data-map-active-collection={mapActiveCollection}
  >
    <PersistentMap />
    <slot />

    <script>
      import '@scripts/theme';
      import '@scripts/animations/init';
      import '@scripts/analytics';
      import '@scripts/persistent-map-init';
    </script>
  </body>
</html>
