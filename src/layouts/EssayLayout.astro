---
import BaseLayout from './BaseLayout.astro';
import PhotoLightbox from '@components/photo/PhotoLightbox.astro';
import '@styles/essay.css';

interface PhotoInfo {
  url: string;
  width: number;
  height: number;
  title: string;
  lqip: string;
  exif?: {
    camera?: string;
    lens?: string;
    focalLength?: string;
    aperture?: string;
    shutter?: string;
    iso?: number;
  };
}

interface Props {
  title: string;
  description?: string;
  photos: PhotoInfo[];
}

const { title, description, photos } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <script is:inline>
    document.body.setAttribute('data-essay', '');
  </script>

  <div class="essay-progress" data-essay-progress aria-hidden="true"></div>

  <main>
    <slot />
  </main>

  <nav class="essay-nav-dots" data-essay-dots aria-label="Essay navigation"></nav>

  <PhotoLightbox photos={photos} />

  <script>
    import '@scripts/essay-nav';
  </script>
</BaseLayout>
