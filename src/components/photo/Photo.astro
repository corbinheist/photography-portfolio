---
/**
 * Responsive photo component with AVIF/WebP srcset and LQIP blur placeholder.
 *
 * The `url` prop is the base CDN URL for the photo (without extension/width).
 * Generates srcset for standard widths: 640, 750, 1080, 1600, 2400 (capped at native width)
 */
import { buildPhotoUrl, buildWidthList } from '../../scripts/utils/photo-widths';

interface Props {
  url: string;
  width: number;
  height: number;
  lqip: string;
  alt: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  lightboxIndex?: number;
}

const {
  url,
  width,
  height,
  lqip,
  alt,
  sizes = '(max-width: 640px) 100vw, (max-width: 1080px) 80vw, 60vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className,
  lightboxIndex,
} = Astro.props;

const slug = url.split('/').pop() || '';
const widths = buildWidthList(width);

function buildSrcset(format: 'avif' | 'webp'): string {
  return widths
    .map((w) => `${url}/${slug}-${w}.${format} ${w}w`)
    .join(', ');
}

const avifSrcset = buildSrcset('avif');
const webpSrcset = buildSrcset('webp');
const fallbackSrc = buildPhotoUrl(url, width, 1080);
---

<div class:list={['photo-wrap', className]} {...(lightboxIndex !== undefined ? { 'data-lightbox-index': lightboxIndex } : {})}>
  <picture>
    <source type="image/avif" srcset={avifSrcset} sizes={sizes} />
    <source type="image/webp" srcset={webpSrcset} sizes={sizes} />
    <img
      src={fallbackSrc}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      style={`background-image: url(${lqip}); background-size: cover;`}
      class="photo-img"
    />
  </picture>
</div>

<style>
  .photo-wrap {
    overflow: hidden;
    line-height: 0;
  }

  .photo-img {
    width: 100%;
    object-fit: cover;
    background-repeat: no-repeat;
    background-position: center;
    transition: opacity 0.4s ease;
  }
</style>
