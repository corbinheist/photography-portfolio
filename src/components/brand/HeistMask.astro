---
interface Props {
  /** Width in pixels — height follows aspect ratio */
  size?: number;
  class?: string;
}

const { size = 48, class: className } = Astro.props;
const height = Math.round(size * 52 / 120);
---

<svg
  class={className}
  width={size}
  height={height}
  viewBox="0 0 120 52"
  fill="currentColor"
  fill-rule="evenodd"
  aria-hidden="true"
>
  <!-- Mask body with eye cutouts -->
  <path d="M12 26C12 8 28 2 44 8c6 3 10 7 16 18 6-11 10-15 16-18C92 2 108 8 108 26S92 50 76 44c-6-3-10-7-16-18-6 11-10 15-16 18C28 50 12 44 12 26Zm16 0a10 8 0 1 0 20 0 10 8 0 1 0-20 0Zm44 0a10 8 0 1 0 20 0 10 8 0 1 0-20 0Z"/>
  <!-- Ribbon ties -->
  <path d="M12 24C6 20 2 14 0 8c2 8 6 14 12 20Z"/>
  <path d="M108 24c6-4 10-10 12-16-2 8-6 14-12 20Z"/>
</svg>
