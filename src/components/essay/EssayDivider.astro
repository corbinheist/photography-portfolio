---
/**
 * Numbered section divider — hairline rule with section number and label.
 * Used between essay acts, not as a standalone snap slide.
 *
 * Renders: 01 ——————————— I · ARRIVAL & CAMP
 */

interface Props {
  /** Two-digit section number, e.g. "01" */
  num: string;
  /** Section label, e.g. "I · ARRIVAL & CAMP" */
  label: string;
}

const { num, label } = Astro.props;
---

<div class="essay-divider">
  <span class="essay-divider__num">{num}</span>
  <span class="essay-divider__rule"></span>
  <span class="essay-divider__label">{label}</span>
</div>

<style>
  .essay-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 28px 56px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .essay-divider__rule {
    flex: 1;
    height: 1px;
    background: var(--color-border-subtle);
  }

  @media (max-width: 768px) {
    .essay-divider {
      padding: 20px var(--container-padding);
    }
  }
</style>
