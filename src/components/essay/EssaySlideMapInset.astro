---
/**
 * Map inset slide — location card + real MapLibre map.
 * Two-column layout: left has text card with metadata,
 * right hosts the reusable <Map> component (MapLibre GL).
 */
import Map from '@components/Map.astro';

interface MarkerDef {
  lng: number;
  lat: number;
  label: string;
  num?: string;
  target?: string;
}

interface Props {
  heading: string;
  description?: string;
  metadata?: Array<{ label: string; value: string }>;
  center: [number, number];
  zoom?: number;
  markers?: MarkerDef[];
  regions?: GeoJSON.FeatureCollection;
  route?: GeoJSON.Feature;
  theme?: string;
}

const {
  heading,
  description,
  metadata = [],
  center,
  zoom = 7,
  markers = [],
  regions,
  route,
  theme = 'default',
} = Astro.props;
---

<section class="essay-slide essay-map-inset">
  <div class="essay-map-inset__card">
    <p class="essay-ov" style="color: var(--color-accent);">LOCATION</p>
    <h2>{heading}</h2>
    {description && <p>{description}</p>}

    {metadata.length > 0 && (
      <div class="essay-map-inset__meta">
        {metadata.map((item) => (
          <div class="essay-map-inset__meta-row">
            <span class="essay-map-inset__meta-k">{item.label}</span>
            {item.value}
          </div>
        ))}
      </div>
    )}
  </div>

  <div class="essay-map-inset__viz">
    <Map
      center={center}
      zoom={zoom}
      markers={markers}
      regions={regions}
      route={route}
      interactive={false}
      theme={theme}
    />
  </div>
</section>

<style>
  .essay-map-inset {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100dvh;
    align-items: stretch;
  }

  .essay-map-inset__card {
    padding: 72px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    border-right: 1px solid var(--color-border-subtle);
  }

  .essay-map-inset__card h2 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .essay-map-inset__card p {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
  }

  .essay-map-inset__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-top: 12px;
  }

  .essay-map-inset__meta-row {
    display: flex;
  }

  .essay-map-inset__meta-k {
    color: var(--color-text-faint);
    display: inline-block;
    width: 96px;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.12em;
  }

  .essay-map-inset__viz {
    position: relative;
    background: var(--color-surface);
  }

  /* .map-container is rendered inside <Map> child component */
  .essay-map-inset__viz :global(.map-container) {
    width: 100%;
    height: 100dvh;
  }

  @media (max-width: 768px) {
    .essay-map-inset {
      grid-template-columns: 1fr;
    }

    .essay-map-inset__card {
      border-right: none;
      border-bottom: 1px solid var(--color-border-subtle);
      padding: 48px var(--container-padding);
    }

    .essay-map-inset__viz {
      min-height: 300px;
    }
  }
</style>
