---
/**
 * Map inset slide — location card on the left, persistent-map slot on
 * the right. The right column does NOT mount its own MapLibre instance;
 * instead the persistent map (in BaseLayout) docks into this slot when
 * the slide enters viewport. The data attrs on the slot tell the
 * persistent-map controller where to fly the camera and which markers
 * to surface.
 */

interface MarkerDef {
  lng: number;
  lat: number;
  label: string;
  num?: string;
  target?: string;
}

interface Props {
  heading: string;
  description?: string;
  metadata?: Array<{ label: string; value: string }>;
  center: [number, number];
  zoom?: number;
  markers?: MarkerDef[];
  regions?: GeoJSON.FeatureCollection;
  route?: GeoJSON.Feature;
  /**
   * Optional collection-id binding so the persistent map can surface
   * the same regional polygon set that lives on /work/[collection].
   * Falls back to no-collection (markers + route only).
   */
  collectionId?: string;
}

const {
  heading,
  description,
  metadata = [],
  center,
  zoom = 7,
  markers = [],
  regions,
  route,
  collectionId,
} = Astro.props;
---

<section class="essay-slide essay-map-inset">
  <div class="essay-map-inset__card">
    <p class="essay-ov" style="color: var(--color-accent);">LOCATION</p>
    <h2>{heading}</h2>
    {description && <p>{description}</p>}

    {metadata.length > 0 && (
      <div class="essay-map-inset__meta">
        {metadata.map((item) => (
          <div class="essay-map-inset__meta-row">
            <span class="essay-map-inset__meta-k">{item.label}</span>
            {item.value}
          </div>
        ))}
      </div>
    )}
  </div>

  <div
    class="essay-map-inset__viz"
    data-map-inset-slot
    data-map-target-center={JSON.stringify(center)}
    data-map-target-zoom={String(zoom)}
    data-map-active-collection={collectionId}
    data-map-inset-markers={markers.length > 0 ? JSON.stringify(markers) : undefined}
    data-map-inset-route={route ? JSON.stringify(route) : undefined}
    data-map-inset-regions={regions ? JSON.stringify(regions) : undefined}
  >
    <!-- Persistent map (in BaseLayout) docks here on scroll. -->
  </div>
</section>

<style>
  .essay-map-inset {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100dvh;
    align-items: stretch;
  }

  .essay-map-inset__card {
    padding: 72px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    border-right: 1px solid var(--color-border-subtle);
  }

  .essay-map-inset__card h2 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .essay-map-inset__card p {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
  }

  .essay-map-inset__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-top: 12px;
  }

  .essay-map-inset__meta-row {
    display: flex;
  }

  .essay-map-inset__meta-k {
    color: var(--color-text-faint);
    display: inline-block;
    width: 96px;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.12em;
  }

  /* Slot reserves the right column. The persistent map (in BaseLayout,
     position: fixed) paints over it — events pass through. */
  .essay-map-inset__viz {
    position: relative;
    background: var(--color-surface);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .essay-map-inset {
      grid-template-columns: 1fr;
    }

    .essay-map-inset__card {
      border-right: none;
      border-bottom: 1px solid var(--color-border-subtle);
      padding: 48px var(--container-padding);
    }

    .essay-map-inset__viz {
      min-height: 300px;
    }
  }
</style>
