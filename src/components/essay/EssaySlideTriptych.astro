---
/**
 * Triptych slide — three images side by side, flex-ratio matched heights.
 * Wraps to 2+1 on mobile.
 */
import Photo from '@components/photo/Photo.astro';
import EssayPlaceholder from './EssayPlaceholder.astro';

interface PhotoData {
  url: string;
  width: number;
  height: number;
  lqip: string;
  alt: string;
  lightboxIndex?: number;
  /** When set, renders a placeholder wireframe instead of a Photo */
  placeholder?: { id: string; title: string };
}

interface Props {
  photos: [PhotoData, PhotoData, PhotoData];
  gap?: 'none' | 'tight' | 'normal';
  caption?: string;
}

const { photos, gap = 'tight', caption } = Astro.props;

const isPortrait = photos.every((p) => p.height > p.width);
const orientation = isPortrait ? 'portrait' : 'landscape';
---

<section class:list={['essay-slide', 'essay-triptych', `essay-triptych--${orientation}`]}>
  <div class:list={['essay-triptych__images', `essay-triptych__images--gap-${gap}`]}>
    {photos.map((photo) => (
      <div class="essay-triptych__item" style={`flex: ${photo.width / photo.height}`}>
        {photo.placeholder ? (
          <EssayPlaceholder id={photo.placeholder.id} title={photo.placeholder.title} layout="triptych" />
        ) : (
          <Photo
            url={photo.url}
            width={photo.width}
            height={photo.height}
            lqip={photo.lqip}
            alt={photo.alt}
            sizes={isPortrait ? '(max-width: 768px) 50vw, 28vw' : '(max-width: 768px) 50vw, 33vw'}
            lightboxIndex={photo.lightboxIndex}
          />
        )}
      </div>
    ))}
  </div>
  {caption && <div class="essay-triptych__caption">{caption}</div>}
</section>
