---
/**
 * Mini gallery slide — masonry grid of 4-12 images within a single snap slide.
 * For showing a collection of moments without giving each its own full-bleed pane.
 */
import Photo from '@components/photo/Photo.astro';

interface PhotoData {
  url: string;
  width: number;
  height: number;
  lqip: string;
  alt: string;
  lightboxIndex?: number;
}

interface Props {
  photos: PhotoData[];
  columns?: 2 | 3;
  caption?: string;
}

const { photos, columns = 3, caption } = Astro.props;
---

<section class="essay-slide essay-mini-gallery">
  <div class:list={['essay-mini-gallery__grid', columns === 2 && 'essay-mini-gallery__grid--cols-2']}>
    {photos.map((photo) => (
      <div class="essay-mini-gallery__item">
        <Photo
          url={photo.url}
          width={photo.width}
          height={photo.height}
          lqip={photo.lqip}
          alt={photo.alt}
          sizes={`(max-width: 768px) 50vw, ${Math.round(100 / columns)}vw`}
          lightboxIndex={photo.lightboxIndex}
        />
      </div>
    ))}
  </div>
  {caption && <div class="essay-mini-gallery__caption">{caption}</div>}
</section>

<style>
  .essay-mini-gallery {
    flex-direction: column;
    padding: 0;
  }

  .essay-mini-gallery__grid {
    columns: 3;
    column-gap: var(--space-sm);
    width: 100%;
    max-width: 2000px;
    margin-inline: auto;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: var(--space-sm);
  }

  .essay-mini-gallery__grid--cols-2 {
    columns: 2;
  }

  .essay-mini-gallery__item {
    break-inside: avoid;
    margin-bottom: var(--space-sm);
    line-height: 0;
  }

  /* .photo-img is rendered by <Photo> child component — :global() to skip cid match */
  .essay-slide .essay-mini-gallery__item :global(.photo-img) {
    width: 100%;
    height: auto;
    max-height: 105dvh;
    object-fit: cover;
  }

  .essay-mini-gallery__caption {
    width: 100%;
    text-align: center;
    padding: var(--space-sm) var(--container-padding);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .essay-mini-gallery__grid {
      columns: 2;
    }

    .essay-mini-gallery__grid--cols-2 {
      columns: 2;
    }
  }
</style>
