---
/**
 * Image + text split slide — 55/45 split with prose alongside image.
 * `flip` reverses to 45/55 with image on the right.
 */
import Photo from '@components/photo/Photo.astro';
import EssayPlaceholder from './EssayPlaceholder.astro';

interface Props {
  url: string;
  width: number;
  height: number;
  lqip?: string;
  alt: string;
  lightboxIndex?: number;
  /** Reverse layout: image right, text left */
  flip?: boolean;
  /** When set, renders a placeholder wireframe instead of a Photo */
  placeholder?: { id: string; title: string };
  /** Mark as image frame for dossier chrome counter */
  frameSlide?: boolean;
}

const {
  url,
  width,
  height,
  lqip,
  alt,
  lightboxIndex,
  flip = false,
  placeholder,
  frameSlide = false,
} = Astro.props;

const isPortrait = height > width;
---

<section
  class:list={[
    'essay-slide',
    'essay-image-text',
    flip && 'essay-image-text--flip',
    isPortrait && 'essay-image-text--portrait',
  ]}
  {...(frameSlide ? { 'data-essay-frame-slide': '' } : {})}
>
  <div class="essay-image-text__image">
    {placeholder ? (
      <EssayPlaceholder id={placeholder.id} title={placeholder.title} layout={flip ? 'image-text (flip)' : 'image-text'} />
    ) : (
      <Photo
        url={url}
        width={width}
        height={height}
        lqip={lqip!}
        alt={alt}
        sizes="(max-width: 768px) 100vw, 55vw"
        lightboxIndex={lightboxIndex}
      />
    )}
  </div>
  <div class="essay-image-text__prose">
    <slot />
  </div>
</section>

<style>
  .essay-image-text {
    display: grid;
    grid-template-columns: 55fr 45fr;
    min-height: 100dvh;
    padding: 0;
  }

  .essay-image-text--flip {
    grid-template-columns: 45fr 55fr;
  }

  .essay-image-text__image {
    position: relative;
    overflow: hidden;
    display: flex;
  }

  /* .photo-wrap / picture / .photo-img from <Photo> child component */
  .essay-image-text__image :global(.photo-wrap) {
    flex: 1;
    min-width: 0;
  }

  .essay-image-text__image :global(.photo-wrap picture) {
    display: block;
    height: 100%;
  }

  .essay-slide .essay-image-text__image :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Portrait images in splits — anchor to top so faces aren't cropped */
  .essay-slide.essay-image-text--portrait .essay-image-text__image :global(.photo-img) {
    object-position: top center;
  }

  .essay-image-text--flip .essay-image-text__image {
    order: 2;
  }

  .essay-image-text--flip .essay-image-text__prose {
    order: 1;
  }

  /* :has() subject is the component-owned root; .essay-placeholder check inside
     :has refers to a class rendered by <EssayPlaceholder> child, but :has() only
     tests for descendant existence by selector match — wrapping in :global() to
     avoid Astro adding a cid that the placeholder element wouldn't have. */
  .essay-image-text:has(:global(.essay-placeholder)) {
    align-items: stretch;
  }

  .essay-image-text__prose {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-2xl) var(--space-xl);
    max-width: 680px;
  }

  /* Slotted children — :global() since slot content carries the parent page's cid */
  .essay-image-text__prose :global(h2),
  .essay-image-text__prose :global(h3) {
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .essay-image-text__prose :global(h2) {
    font-size: var(--text-2xl);
  }

  .essay-image-text__prose :global(h3) {
    font-size: var(--text-xl);
  }

  .essay-image-text__prose :global(p) {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 55ch;
  }

  .essay-image-text__prose :global(p + p) {
    margin-top: var(--space-md);
  }

  .essay-image-text__prose :global(p strong) {
    color: var(--color-text);
    font-weight: 500;
  }

  .essay-image-text__prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-md);
    margin: var(--space-lg) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .essay-image-text {
      grid-template-columns: 1fr;
    }

    .essay-image-text__image {
      position: relative;
      min-height: 50dvh;
    }

    .essay-image-text--flip .essay-image-text__image {
      order: 0;
    }

    .essay-image-text--flip .essay-image-text__prose {
      order: 0;
    }

    .essay-image-text__prose {
      padding: var(--space-xl) var(--container-padding);
    }
  }
</style>
