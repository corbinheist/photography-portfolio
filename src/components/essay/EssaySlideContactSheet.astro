---
/**
 * Contact sheet slide — 6-column grid of thumbnails with frame numbers.
 * Evokes an analog contact sheet / proof sheet.
 */
import Photo from '@components/photo/Photo.astro';

interface Props {
  photos: Array<{
    url: string;
    width: number;
    height: number;
    lqip: string;
    alt: string;
    lightboxIndex?: number;
  }>;
  heading?: string;
  caption?: string;
  footerLeft?: string;
  footerRight?: string;
}

const { photos, heading, caption, footerLeft, footerRight } = Astro.props;
---

<section class="essay-slide essay-contact-sheet">
  <div class="essay-contact-sheet__head">
    <div>
      {heading && <p class="essay-ov" style="color: var(--color-accent);">{heading}</p>}
      {caption && <h3>{caption}</h3>}
    </div>
    <span class="essay-contact-sheet__count">{photos.length} FRAMES &middot; SELECT</span>
  </div>

  <div class="essay-contact-sheet__grid">
    {photos.map((photo, i) => (
      <div class="essay-contact-sheet__cell">
        <Photo
          url={photo.url}
          width={photo.width}
          height={photo.height}
          lqip={photo.lqip}
          alt={photo.alt}
          sizes="(max-width: 768px) 33vw, 16vw"
          lightboxIndex={photo.lightboxIndex}
        />
        <span class="essay-contact-sheet__num">{String(i + 1).padStart(2, '0')}</span>
      </div>
    ))}
  </div>

  {(footerLeft || footerRight) && (
    <div class="essay-contact-sheet__foot">
      <span>{footerLeft || ''}</span>
      <span>{footerRight || ''}</span>
    </div>
  )}
</section>

<style>
  .essay-contact-sheet {
    padding: 80px 56px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .essay-contact-sheet__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
  }

  .essay-contact-sheet__head h3 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(1.375rem, 1.15rem + 1vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 8px 0 0;
  }

  .essay-contact-sheet__count {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    text-align: right;
  }

  .essay-contact-sheet__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
  }

  .essay-contact-sheet__cell {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #000;
  }

  /* .photo-wrap / picture / .photo-img from <Photo> child component */
  .essay-contact-sheet__cell :global(.photo-wrap) {
    width: 100%;
    height: 100%;
  }

  .essay-contact-sheet__cell :global(.photo-wrap picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .essay-slide .essay-contact-sheet__cell :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .essay-contact-sheet__num {
    position: absolute;
    top: 4px;
    left: 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--fx-paper);
    mix-blend-mode: difference;
    letter-spacing: 0.1em;
  }

  .essay-contact-sheet__foot {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    display: flex;
    justify-content: space-between;
  }

  @media (max-width: 768px) {
    .essay-contact-sheet {
      padding: 48px var(--container-padding);
    }

    .essay-contact-sheet__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
