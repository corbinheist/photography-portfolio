---
/**
 * Related dossiers slide — feature card + numbered list.
 * Shows at the end of an essay, after the colophon.
 */
import Photo from '@components/photo/Photo.astro';

interface RelatedDossier {
  title: string;
  slug: string;
  description?: string;
  location?: string;
  coverUrl?: string;
  coverWidth?: number;
  coverHeight?: number;
  coverLqip?: string;
  dossierLabel?: string;
}

interface Props {
  heading?: string;
  featured: RelatedDossier;
  others?: RelatedDossier[];
  allDossiersHref?: string;
}

const { heading = 'Next from the archive.', featured, others = [], allDossiersHref } = Astro.props;
---

<section class="essay-slide essay-related">
  <div class="essay-related__head">
    <div>
      <p class="essay-ov" style="color: var(--color-accent);">◆ CONTINUE THE FIELD</p>
      <h2>{heading}</h2>
    </div>
    {allDossiersHref && (
      <a href={allDossiersHref} class="essay-related__link">All dossiers &rarr;</a>
    )}
  </div>

  <div class="essay-related__body">
    <a class="essay-related__feature" href={featured.slug}>
      {featured.coverUrl && featured.coverWidth && featured.coverHeight && featured.coverLqip && (
        <div class="essay-related__feature-thumb">
          <Photo
            url={featured.coverUrl}
            width={featured.coverWidth}
            height={featured.coverHeight}
            lqip={featured.coverLqip}
            alt={featured.title}
            sizes="(max-width: 768px) 100vw, 30vw"
          />
        </div>
      )}
      <div class="essay-related__feature-meta">
        {featured.dossierLabel && <p class="essay-ov" style="color: var(--color-accent);">{featured.dossierLabel}</p>}
        <h3>{featured.title}.</h3>
        {featured.description && <p class="essay-related__feature-desc">{featured.description}</p>}
        {featured.location && <p class="essay-related__feature-loc">{featured.location}</p>}
        <p class="essay-related__feature-cta">Read dossier &rarr;</p>
      </div>
    </a>

    {others.length > 0 && (
      <ol class="essay-related__list">
        {others.map((item) => (
          <li>
            <a href={item.slug} class="essay-related__row">
              <span class="essay-related__row-num">{item.dossierLabel || ''}</span>
              {item.coverUrl && item.coverWidth && item.coverHeight && item.coverLqip && (
                <span class="essay-related__row-thumb">
                  <Photo
                    url={item.coverUrl}
                    width={item.coverWidth}
                    height={item.coverHeight}
                    lqip={item.coverLqip}
                    alt={item.title}
                    sizes="72px"
                  />
                </span>
              )}
              <span class="essay-related__row-info">
                <span class="essay-related__row-title">{item.title}</span>
                {item.description && <span class="essay-related__row-desc">{item.description}</span>}
              </span>
              {item.location && <span class="essay-related__row-loc">{item.location}</span>}
            </a>
          </li>
        ))}
      </ol>
    )}
  </div>

  <div class="essay-related__foot">
    <span>HEIST.STUDIO &middot; ESSAYS &middot; SELF-HOSTED &middot; NO TRACKING</span>
    <span>{new Date().getFullYear()}</span>
  </div>
</section>

<style>
  .essay-related {
    padding: 72px 64px 48px;
    display: flex;
    flex-direction: column;
    gap: 36px;
    justify-content: center;
  }

  .essay-related__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .essay-related__head > div {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .essay-related__head h2 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(2.25rem, 1.6rem + 2.5vw, 3rem);
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.08;
  }

  .essay-related__link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    transition: color 150ms;
  }

  .essay-related__link:hover {
    color: var(--color-accent-hover);
  }

  .essay-related__body {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 48px;
  }

  .essay-related__feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    text-decoration: none;
    color: inherit;
    align-items: stretch;
  }

  .essay-related__feature-thumb {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #000;
  }

  /* .photo-wrap / picture / .photo-img from <Photo> child component */
  .essay-related__feature-thumb :global(.photo-wrap) {
    width: 100%;
    height: 100%;
  }

  .essay-related__feature-thumb :global(.photo-wrap picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .essay-slide .essay-related__feature-thumb :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 250ms;
  }

  .essay-related__feature:hover :global(.photo-img) {
    opacity: 0.85;
  }

  .essay-related__feature-meta {
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: space-between;
    padding: 4px 0;
  }

  .essay-related__feature-meta h3 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: 32px;
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin: 0;
  }

  .essay-related__feature-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: 40ch;
  }

  .essay-related__feature-loc {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 0;
  }

  .essay-related__feature-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
    padding-top: 8px;
    border-top: 1px solid var(--color-border-subtle);
  }

  .essay-related__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .essay-related__list li {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .essay-related__list li:first-child {
    border-top: 1px solid var(--color-border-subtle);
  }

  .essay-related__row {
    display: grid;
    grid-template-columns: 72px 88px 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 16px 0;
    text-decoration: none;
    color: inherit;
  }

  .essay-related__row-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  .essay-related__row-thumb {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #000;
    width: 72px;
  }

  .essay-related__row-thumb :global(.photo-wrap) {
    width: 100%;
    height: 100%;
  }

  .essay-related__row-thumb :global(.photo-wrap picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .essay-slide .essay-related__row-thumb :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 200ms;
  }

  .essay-related__row:hover :global(.photo-img) {
    opacity: 0.85;
  }

  .essay-related__row:hover .essay-related__row-num {
    color: var(--color-accent);
  }

  .essay-related__row-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .essay-related__row-title {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: 18px;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .essay-related__row-desc {
    font-size: 12.5px;
    color: var(--color-text-muted);
    line-height: 1.5;
    max-width: 48ch;
  }

  .essay-related__row-loc {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--color-text-faint);
    text-transform: uppercase;
    text-align: right;
  }

  .essay-related__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  @media (max-width: 768px) {
    .essay-related {
      padding: 48px var(--container-padding);
    }

    .essay-related__body {
      grid-template-columns: 1fr;
    }

    .essay-related__feature {
      grid-template-columns: 1fr;
    }

    .essay-related__feature-thumb {
      aspect-ratio: 16 / 9;
    }

    .essay-related__row {
      grid-template-columns: 48px 64px 1fr;
    }

    .essay-related__row-loc {
      display: none;
    }
  }
</style>
