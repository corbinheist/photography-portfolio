---
/**
 * Dossier hero slide — full-bleed image with left-weighted gradient,
 * dossier manifest overlay, and scroll indicator.
 */
import Photo from '@components/photo/Photo.astro';

interface Props {
  url: string;
  width: number;
  height: number;
  lqip?: string;
  alt: string;
  lightboxIndex?: number;
  loading?: 'lazy' | 'eager';
  /** Dossier number, e.g. "011" */
  dossierNum: string;
  /** Dossier sequence number, e.g. "N° 01" */
  sequenceNum: string;
  /** Overline text (location · region), e.g. "Djebel Saghro · Anti-Atlas · Morocco" */
  overline: string;
  /** Big h1 title */
  title: string;
  /** Deck paragraph */
  deck: string;
  /** Manifest bar data — 5 columns */
  manifest: {
    region: string;
    coords: string;
    elev?: string;
    date: string;
    frames: string;
  };
}

const {
  url, width, height, lqip, alt, lightboxIndex,
  loading = 'eager',
  dossierNum, sequenceNum, overline, title, deck, manifest,
} = Astro.props;
---

<section class="essay-slide essay-hero" data-essay-frame-slide>
  <div class="essay-hero__img">
    <Photo
      url={url}
      width={width}
      height={height}
      lqip={lqip!}
      alt={alt}
      sizes="100vw"
      loading={loading}
      lightboxIndex={lightboxIndex}
    />
  </div>

  <div class="essay-hero__gradient"></div>

  <div class="essay-hero__inner">
    <div class="essay-hero__top">
      <div class="essay-hero__stamp">
        <span class="essay-hero__stamp-mark"></span>
        <span>FIELD</span>
      </div>
      <div>{sequenceNum} &middot; DOSSIER {dossierNum}</div>
    </div>

    <div class="essay-hero__body">
      <p class="essay-ov" style="color: var(--fx-base-200); opacity: 0.7;">
        {overline} &middot; {manifest.coords}
      </p>
      <h1 class="essay-hero__title">{title}</h1>
      <p class="essay-hero__deck">{deck}</p>
    </div>

    <div class="essay-hero__manifest">
      <div class="essay-hero__manifest-cell">
        <span class="essay-hero__manifest-k">Region</span>
        <span class="essay-hero__manifest-v">{manifest.region}</span>
      </div>
      <div class="essay-hero__manifest-cell">
        <span class="essay-hero__manifest-k">Coords</span>
        <span class="essay-hero__manifest-v">{manifest.coords}</span>
      </div>
      {manifest.elev && (
        <div class="essay-hero__manifest-cell">
          <span class="essay-hero__manifest-k">Elev.</span>
          <span class="essay-hero__manifest-v">{manifest.elev}</span>
        </div>
      )}
      <div class="essay-hero__manifest-cell">
        <span class="essay-hero__manifest-k">Date</span>
        <span class="essay-hero__manifest-v">{manifest.date}</span>
      </div>
      <div class="essay-hero__manifest-cell">
        <span class="essay-hero__manifest-k">Frames</span>
        <span class="essay-hero__manifest-v">{manifest.frames}</span>
      </div>
    </div>
  </div>

  <div class="essay-hero__scroll">
    <span>BEGIN</span>
    <span>&darr;</span>
  </div>
</section>

<style>
  .essay-hero {
    position: relative;
    overflow: hidden;
    background: #000;
  }

  .essay-hero__img {
    position: absolute;
    inset: 0;
  }

  /* .photo-wrap / picture / .photo-img from <Photo> child component */
  .essay-hero__img :global(.photo-wrap) {
    width: 100%;
    height: 100%;
  }

  .essay-hero__img :global(.photo-wrap picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .essay-slide .essay-hero__img :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .essay-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(16, 15, 15, 0.72) 0%,
      rgba(16, 15, 15, 0.45) 40%,
      rgba(16, 15, 15, 0.15) 70%,
      rgba(16, 15, 15, 0) 100%
    );
    z-index: 1;
  }

  .essay-hero__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 56px 56px 40px;
    color: var(--fx-base-100);
  }

  .essay-hero__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fx-base-200);
  }

  .essay-hero__stamp {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .essay-hero__stamp-mark {
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-accent);
    display: inline-block;
    transform: rotate(45deg);
  }

  .essay-hero__body {
    align-self: end;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 820px;
  }

  /* Defensive: .essay-ov is hand-authored in this component's template (gets cid),
     but the inline style on the rendered <p> already wins by specificity 1,0,0,0
     so this rule effectively never applies. .essay-ov__diamond never appears in
     Hero's template — kept for parity with the original. */
  .essay-hero__body .essay-ov {
    color: var(--fx-base-200);
    opacity: 0.7;
  }

  .essay-hero__body .essay-ov__diamond {
    color: var(--fx-base-200);
  }

  .essay-hero__title {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(3.5rem, 2.5rem + 3.5vw, 5.75rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--fx-paper);
    margin: 0;
  }

  .essay-hero__deck {
    font-size: 18px;
    line-height: 1.5;
    color: var(--fx-base-100);
    max-width: 56ch;
    margin: 0;
  }

  .essay-hero__manifest {
    border-top: 1px solid rgba(230, 228, 217, 0.25);
    padding-top: 18px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fx-base-200);
  }

  .essay-hero__manifest-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .essay-hero__manifest-k {
    color: var(--fx-base-300);
    opacity: 0.7;
    font-size: 9px;
  }

  .essay-hero__manifest-v {
    color: var(--fx-paper);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .essay-hero__scroll {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--fx-base-200);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .essay-hero__inner {
      padding: 48px var(--container-padding) 32px;
    }

    .essay-hero__manifest {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .essay-hero__manifest-cell:nth-child(n + 4) {
      display: none;
    }

    .essay-hero__title {
      font-size: clamp(2.5rem, 2rem + 2vw, 3.5rem);
    }

    .essay-hero__top {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
