---
/**
 * Timeline slide — vertical field-journal entries with time, label, and note.
 * Used for showing the rhythm of a day in the field.
 */
import EssayOverline from './EssayOverline.astro';

interface Props {
  overline?: string;
  dossierNum?: string;
  heading: string;
  lead?: string;
  entries: Array<{ time: string; label: string; note?: string; active?: boolean }>;
}

const { overline, dossierNum, heading, lead, entries } = Astro.props;
---

<section class="essay-slide essay-timeline">
  <div class="essay-timeline__head">
    <div class="essay-timeline__head-left">
      {overline && dossierNum && <EssayOverline num={dossierNum} text={overline} />}
      {overline && !dossierNum && <p class="essay-ov">{overline}</p>}
      <h2>{heading}</h2>
    </div>
    {lead && <p class="essay-timeline__lead">{lead}</p>}
  </div>

  <ol class="essay-timeline__list">
    {entries.map((entry) => (
      <li class:list={['essay-timeline__entry', entry.active && 'essay-timeline__entry--active']}>
        <div class="essay-timeline__time">
          <span class="essay-timeline__hhmm">{entry.time}</span>
          <span class="essay-timeline__tick"></span>
        </div>
        <div class="essay-timeline__body">
          <h4>{entry.label}</h4>
          {entry.note && <p>{entry.note}</p>}
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .essay-timeline {
    padding: 88px 72px 64px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    justify-content: center;
  }

  .essay-timeline__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 48px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .essay-timeline__head-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 520px;
  }

  .essay-timeline__head-left h2 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .essay-timeline__lead {
    max-width: 40ch;
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    text-align: right;
    margin: 0;
  }

  .essay-timeline__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .essay-timeline__entry {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 40px;
    padding: 22px 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .essay-timeline__entry:last-child {
    border-bottom: none;
  }

  .essay-timeline__time {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .essay-timeline__hhmm {
    font-size: 15px;
    letter-spacing: 0.05em;
  }

  .essay-timeline__tick {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .essay-timeline__entry--active .essay-timeline__time {
    color: var(--hs-moss);
  }

  .essay-timeline__entry--active .essay-timeline__tick {
    background: var(--color-accent);
  }

  .essay-timeline__body h4 {
    font-family: var(--font-heading);
    font-weight: var(--heading-weight, 500);
    font-size: 22px;
    color: var(--color-text);
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .essay-timeline__body p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    max-width: 64ch;
  }

  @media (max-width: 768px) {
    .essay-timeline {
      padding: 64px var(--container-padding) 48px;
    }

    .essay-timeline__head {
      flex-direction: column;
      align-items: flex-start;
    }

    .essay-timeline__lead {
      text-align: left;
    }

    .essay-timeline__entry {
      grid-template-columns: 80px 1fr;
      gap: 20px;
    }
  }
</style>
