---
/**
 * Pull-quote slide — centered Vollkorn italic blockquote.
 */

interface Props {
  text: string;
  attribution?: string;
}

const { text, attribution } = Astro.props;
---

<section class="essay-slide essay-quote">
  <div class="essay-quote__inner">
    <div class="essay-quote__overline">Pull quote</div>
    <blockquote class="essay-quote__text">&ldquo;{text}&rdquo;</blockquote>
    {attribution && <div class="essay-quote__attr">&mdash; {attribution}</div>}
  </div>
</section>

<style>
  .essay-quote {
    padding: var(--space-2xl) var(--container-padding);
  }

  .essay-quote__inner {
    max-width: 820px;
    width: 100%;
    text-align: center;
  }

  .essay-quote__overline {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-warm);
    margin-bottom: var(--space-lg);
  }

  .essay-quote__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-3xl);
    line-height: 1.3;
    letter-spacing: -0.02em;
    text-wrap: balance;
    color: var(--color-text);
    border: none;
    padding: 0;
    margin: 0;
  }

  .essay-quote__text::before {
    content: "\201C";
    color: var(--color-accent);
    margin-right: 0.1em;
  }

  .essay-quote__text::after {
    content: "\201D";
    color: var(--color-accent);
    margin-left: 0.1em;
  }

  .essay-quote__attr {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-top: var(--space-lg);
  }
</style>
