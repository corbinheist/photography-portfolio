---
/**
 * Pinned caption slide — full-bleed image with a persistent
 * glass-morphism caption bar fixed at the bottom.
 */
import Photo from '@components/photo/Photo.astro';

interface Props {
  url: string;
  width: number;
  height: number;
  lqip?: string;
  alt: string;
  lightboxIndex?: number;
  caption: string;
  meta?: string;
}

const { url, width, height, lqip, alt, lightboxIndex, caption, meta } = Astro.props;
---

<section class="essay-slide essay-pinned-caption" data-essay-frame-slide>
  <div class="essay-pinned-caption__img">
    <Photo
      url={url}
      width={width}
      height={height}
      lqip={lqip!}
      alt={alt}
      sizes="100vw"
      lightboxIndex={lightboxIndex}
    />
  </div>

  <div class="essay-pinned-caption__bar">
    <span class="essay-pinned-caption__title">{caption}</span>
    {meta && <span>{meta}</span>}
  </div>
</section>

<style>
  .essay-pinned-caption {
    position: relative;
    overflow: hidden;
    background: #000;
  }

  .essay-pinned-caption__img {
    position: absolute;
    inset: 0;
  }

  /* .photo-wrap / .photo-img / picture come from <Photo> child component */
  .essay-pinned-caption__img :global(.photo-wrap) {
    width: 100%;
    height: 100%;
  }

  .essay-pinned-caption__img :global(.photo-wrap picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .essay-slide .essay-pinned-caption__img :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .essay-pinned-caption__bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    background: color-mix(in srgb, var(--color-bg) 80%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .essay-pinned-caption__title {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-text);
    text-transform: none;
    letter-spacing: 0;
  }

  @media (max-width: 768px) {
    .essay-pinned-caption__bar {
      padding: 10px var(--container-padding);
    }
  }
</style>
