---
/**
 * Text-only slide — centered prose for section transitions, titles, pull quotes.
 */

interface Props {
  align?: 'left' | 'center';
  snap?: boolean;
}

const { align = 'center', snap = true } = Astro.props;
---

<section
  class:list={[
    'essay-slide',
    'essay-text',
    `essay-text--${align}`,
  ]}
  {...(snap ? { 'data-essay-snap': '' } : {})}
>
  <div class="essay-text__inner">
    <slot />
  </div>
</section>
