---
/**
 * Placeholder wireframe box — renders in place of a <Photo> when
 * a slide's `placeholder` prop is set.  Shows an ID label, title,
 * and the layout name so the wireframe is self-documenting.
 */
interface Props {
  id: string;
  title: string;
  layout: string;
}

const { id, title, layout } = Astro.props;
---

<div class="essay-placeholder">
  <span class="essay-placeholder__id">{id}</span>
  <span class="essay-placeholder__title">{title}</span>
  <span class="essay-placeholder__layout">{layout}</span>
</div>

<style>
  .essay-placeholder {
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-alt) 100%);
    border: 1px dashed var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
    gap: 6px;
  }

  .essay-placeholder__id {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  .essay-placeholder__title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .essay-placeholder__layout {
    position: absolute;
    bottom: 10px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  /* Layout-specific overrides — parent classes are owned by sibling slide components
     (EssaySlideFullBleed/ImageText/Diptych/Triptych) and also appear in pitch HTML
     with no scope, so the parent must use :global() to skip cid-matching. */
  :global(.essay-full-bleed__img) .essay-placeholder {
    position: absolute;
    inset: 0;
  }

  :global(.essay-image-text__image) .essay-placeholder {
    position: absolute;
    inset: 0;
  }

  :global(.essay-diptych__item) .essay-placeholder {
    height: auto;
    aspect-ratio: 3 / 2;
  }

  :global(.essay-diptych--portrait .essay-diptych__item) .essay-placeholder {
    aspect-ratio: 2 / 3;
    max-height: 85dvh;
  }

  :global(.essay-triptych__item) .essay-placeholder {
    height: auto;
    aspect-ratio: 2 / 3;
    max-height: 75dvh;
  }

  @media (max-width: 768px) {
    :global(.essay-diptych--portrait .essay-diptych__item) .essay-placeholder {
      max-height: 60dvh;
    }

    :global(.essay-triptych__item) .essay-placeholder {
      max-height: 50dvh;
    }
  }
</style>
