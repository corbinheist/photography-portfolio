---
import { buildWidthList } from '../../scripts/utils/photo-widths';

interface Datum {
  label: string;
  value: string;
}

interface Props {
  title: string;
  href: string;
  coverUrl?: string;
  coverWidth?: number;
  coverHeight?: number;
  coverLqip?: string;
  mobileCoverUrl?: string;
  mobileCoverWidth?: number;
  mobileCoverHeight?: number;
  mobileCoverLqip?: string;
  caption: string;
  coords: string;
  meta: string;
  data: Datum[];
  live?: boolean;
}

const { title, href, coverUrl, coverWidth, coverHeight, coverLqip, mobileCoverUrl, mobileCoverWidth, mobileCoverHeight, mobileCoverLqip, caption, coords, meta, data, live } = Astro.props;

const hasImage = coverUrl && coverWidth && coverHeight;
const slug = hasImage ? (coverUrl.split('/').pop() || '') : '';
const widths = hasImage ? buildWidthList(coverWidth) : [];
const hasMobile = mobileCoverUrl && mobileCoverWidth;

function buildSrcset(format: 'avif' | 'webp'): string {
  return widths.map((w) => `${coverUrl}/${slug}-${w}.${format} ${w}w`).join(', ');
}

function buildMobileSrcset(format: 'avif' | 'webp'): string {
  if (!mobileCoverUrl || !mobileCoverWidth) return '';
  const mSlug = mobileCoverUrl.split('/').pop() || '';
  const mWidths = buildWidthList(mobileCoverWidth);
  return mWidths.map((w) => `${mobileCoverUrl}/${mSlug}-${w}.${format} ${w}w`).join(', ');
}
---

<section class:list={['dispatch', { 'dispatch--live': live }]}>
  <div class="dispatch__inner">
    <div class="dispatch__header">
      <div class="dispatch__label">
        <span class="dispatch__dot"></span>
        <span class="dispatch__overline">Current dispatch</span>
      </div>
      <h2 class="dispatch__title">{title}</h2>
      <a href={href} class="dispatch__link">Follow dispatch &rarr;</a>
    </div>

    <div class="dispatch__meta-strip">
      {data.map((item, i) => (
        <>
          <span class="dispatch__meta-k">{item.label}</span>
          <span class="dispatch__meta-v">{item.value}</span>
          {i < data.length - 1 && <span class="dispatch__meta-sep">&middot;</span>}
        </>
      ))}
    </div>

    {hasImage ? (
      <div class="dispatch__hero">
        <picture>
          {hasMobile && (
            <>
              <source media="(max-width: 639px)" type="image/avif" srcset={buildMobileSrcset('avif')} sizes="100vw" />
              <source media="(max-width: 639px)" type="image/webp" srcset={buildMobileSrcset('webp')} sizes="100vw" />
            </>
          )}
          <source type="image/avif" srcset={buildSrcset('avif')} sizes="(max-width: 1440px) 100vw, 1440px" />
          <source type="image/webp" srcset={buildSrcset('webp')} sizes="(max-width: 1440px) 100vw, 1440px" />
          <img
            src={`${coverUrl}/${slug}-1600.webp`}
            alt={title}
            width={coverWidth}
            height={coverHeight}
            loading="lazy"
            decoding="async"
            style={`background-image: url(${hasMobile ? mobileCoverLqip : coverLqip}); background-size: cover;`}
            class="dispatch__img"
          />
        </picture>
        <div class="dispatch__img-overlay">
          <span class="dispatch__img-coords">{coords}</span>
          <span class="dispatch__img-meta">{meta}</span>
        </div>
      </div>
    ) : (
      <div class="dispatch__coords-bar">
        <span class="dispatch__coords-value">{coords}</span>
        <span class="dispatch__coords-meta">{meta}</span>
      </div>
    )}

    <div class="dispatch__meta-grid">
      <div class="dispatch__caption">{caption}</div>
      {data.map((d) => (
        <div class="dispatch__datum">
          <span class="datum__label">{d.label}</span>
          <span class="datum__value">{d.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .dispatch {
    padding: var(--space-2xl) var(--container-padding);
    border-top: 1px solid var(--color-border-subtle);
  }

  .dispatch__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .dispatch__header {
    display: flex;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .dispatch__label {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dispatch__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse-dispatch 2s ease-in-out infinite;
  }

  .dispatch--live .dispatch__dot {
    background: var(--color-warm);
  }

  @keyframes pulse-dispatch {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .dispatch__overline {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .dispatch--live .dispatch__overline {
    color: var(--color-warm);
  }

  .dispatch__title {
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    flex: 1;
  }

  .dispatch__link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--duration-fast) ease;
    white-space: nowrap;
    margin-left: auto;
  }

  .dispatch__link:hover {
    color: var(--color-accent);
  }

  .dispatch--live .dispatch__link:hover {
    color: var(--color-warm);
  }

  /* ── Metadata strip ── */
  .dispatch__meta-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3em 0.6em;
    padding: 10px 20px;
    border-bottom: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .dispatch__meta-k {
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  .dispatch__meta-k::after {
    content: ":";
    margin-right: 0.25em;
  }

  .dispatch__meta-v {
    color: var(--color-text-muted);
  }

  .dispatch__meta-sep {
    color: var(--color-border);
    margin: 0 0.2em;
  }

  /* ── Imageless coords bar (pre-trip dispatches) ── */
  .dispatch__coords-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .dispatch__coords-value {
    color: var(--color-warm);
  }

  .dispatch__coords-meta {
    color: var(--color-text-faint);
  }

  /* ── Hero image ── */
  .dispatch__hero {
    position: relative;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    margin-bottom: 0;
  }

  .dispatch__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-repeat: no-repeat;
    background-position: center;
  }

  .dispatch__img-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 18px;
    background: linear-gradient(to top, rgba(16, 15, 15, 0.7), transparent);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .dispatch__img-coords {
    color: var(--color-accent);
  }

  .dispatch--live .dispatch__img-coords {
    color: var(--color-warm);
  }

  .dispatch__img-meta {
    color: rgba(255, 252, 240, 0.5);
  }

  /* ── Metadata grid ── */
  .dispatch__meta-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    border-top: 1px solid var(--color-border-subtle);
  }

  .dispatch__caption {
    padding: 20px 20px 20px 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 52ch;
    border-right: 1px solid var(--color-border-subtle);
  }

  .dispatch__datum {
    padding: 20px;
    border-right: 1px solid var(--color-border-subtle);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .dispatch__datum:last-child {
    border-right: none;
  }

  .datum__label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .datum__value {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  /* ── Mobile ── */
  @media (max-width: 1023px) {
    .dispatch__meta-grid {
      grid-template-columns: 1fr 1fr;
    }

    .dispatch__caption {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: 1px solid var(--color-border-subtle);
      padding: 20px 0;
    }
  }

  @media (max-width: 639px) {
    .dispatch__header {
      flex-direction: column;
      gap: 12px;
    }

    .dispatch__link {
      margin-left: 0;
    }

    .dispatch__hero {
      aspect-ratio: 3 / 4;
    }

    .dispatch__meta-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
