---
import { buildWidthList } from '../../scripts/utils/photo-widths';

interface ManifestCollection {
  id: string;
  num: string;
  title: string;
  description: string;
  lat: string;
  lon: string;
  elev: string;
  status: string;
  frameCount: number;
  coverUrl?: string;
  coverWidth?: number;
  coverHeight?: number;
  coverLqip?: string;
}

interface Props {
  collections: ManifestCollection[];
  totalCount: number;
}

const { collections, totalCount } = Astro.props;

function thumbSrc(url: string, width: number): string {
  const slug = url.split('/').pop() || '';
  const w = buildWidthList(width).find((w) => w >= 640) || 640;
  return `${url}/${slug}-${w}.webp`;
}
---

<section class="manifest">
  <div class="manifest__inner">
    <div class="manifest__header">
      <div>
        <div class="manifest__overline">MANIFEST &middot; {String(totalCount).padStart(2, '0')} COLLECTIONS</div>
        <h2 class="manifest__heading">Where the camera<br />has been.</h2>
      </div>
      <a href="/work" class="manifest__all-link">All work &rarr;</a>
    </div>

    <div class="manifest__list stagger-children">
      {collections.map((c) => (
        <a href={`/work/${c.id}`} class="manifest-row">
          <span class="manifest-row__num">N&deg; {c.num}</span>

          <span class="manifest-row__thumb">
            {c.coverUrl ? (
              <img
                src={thumbSrc(c.coverUrl, c.coverWidth || 640)}
                alt={c.title}
                loading="lazy"
                decoding="async"
                style={c.coverLqip ? `background-image: url(${c.coverLqip}); background-size: cover;` : ''}
              />
            ) : (
              <span class="manifest-row__placeholder"></span>
            )}
          </span>

          <span class="manifest-row__info">
            <span class="manifest-row__title">{c.title}</span>
            <span class="manifest-row__desc">{c.description}</span>
          </span>

          <span class="manifest-row__coords">
            <span class="coords__latlon">{c.lat}, {c.lon}</span>
            {c.elev && c.elev !== '—' && <span class="coords__elev">{c.elev}</span>}
          </span>

          <span class="manifest-row__status">
            <span class:list={['status-badge', `status-badge--${c.status.toLowerCase().replace(' ', '-')}`]}>
              {c.status}
            </span>
            <span class="manifest-row__frames">{c.frameCount} frames</span>
          </span>

          <span class="manifest-row__arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .manifest {
    padding: var(--space-2xl) var(--container-padding);
    border-top: 1px solid var(--color-border-subtle);
  }

  .manifest__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .manifest__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 48px;
  }

  .manifest__overline {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .manifest__heading {
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0;
    line-height: 1;
  }

  .manifest__all-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--duration-fast) ease;
    white-space: nowrap;
  }

  .manifest__all-link:hover {
    color: var(--color-accent);
  }

  /* ── Row ── */
  .manifest-row {
    display: grid;
    grid-template-columns: 64px 240px 1fr 180px 120px 28px;
    align-items: center;
    gap: 0 20px;
    padding: 16px 12px;
    border-top: 1px solid var(--color-border-subtle);
    transition: background 200ms var(--ease-out-quart);
    cursor: pointer;
  }

  .manifest-row:last-child {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .manifest-row:hover {
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .manifest-row__num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  .manifest-row__thumb {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-surface);
  }

  .manifest-row__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms var(--ease-out-quart);
    background-repeat: no-repeat;
    background-position: center;
  }

  .manifest-row:hover .manifest-row__thumb img {
    transform: scale(1.04);
  }

  .manifest-row__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-surface-alt);
  }

  .manifest-row__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .manifest-row__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-text);
    transition: color var(--duration-fast) ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .manifest-row:hover .manifest-row__title {
    color: var(--color-accent);
  }

  .manifest-row__desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .manifest-row__coords {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .coords__latlon {
    color: var(--color-accent);
  }

  .manifest-row__status {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 2px;
  }

  .status-badge--live {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .status-badge--editing {
    color: var(--color-warm-light);
    background: color-mix(in srgb, var(--color-warm) 12%, transparent);
  }

  .status-badge--published {
    color: var(--color-text-faint);
    background: color-mix(in srgb, var(--color-text-faint) 10%, transparent);
  }

  .status-badge--draft {
    color: var(--color-text-faint);
    background: color-mix(in srgb, var(--color-text-faint) 8%, transparent);
  }

  .manifest-row__frames {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
  }

  .manifest-row__arrow {
    font-size: 16px;
    color: var(--color-text-faint);
    transition: transform 200ms var(--ease-out-quart), color 200ms ease;
    text-align: center;
  }

  .manifest-row:hover .manifest-row__arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  /* ── Mobile ── */
  @media (max-width: 1023px) {
    .manifest-row {
      grid-template-columns: 48px 1fr auto 24px;
      grid-template-rows: auto auto;
      gap: 8px 12px;
    }

    .manifest-row__thumb {
      grid-column: 1 / -1;
      grid-row: 1;
      aspect-ratio: 21 / 9;
    }

    .manifest-row__num {
      grid-row: 2;
    }

    .manifest-row__info {
      grid-row: 2;
    }

    .manifest-row__coords { display: none; }
    .manifest-row__status { display: none; }

    .manifest-row__arrow {
      grid-row: 2;
      align-self: center;
    }
  }

  @media (max-width: 639px) {
    .manifest__header {
      flex-direction: column;
      gap: var(--space-md);
    }

    .manifest-row {
      grid-template-columns: 40px 1fr 24px;
      padding: 12px 0;
    }

    .manifest-row__num {
      grid-row: 2;
    }

    .manifest-row__info {
      grid-row: 2;
    }

    .manifest-row__arrow {
      grid-row: 2;
    }
  }
</style>
