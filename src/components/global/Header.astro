---
import { getCollection } from 'astro:content';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  /** Minimal mode: hamburger only, transparent background, no logo/theme toggle */
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

const collections = (await getCollection('photoCollections'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const allEssays = await getCollection('essays');
const essayById = new Map(allEssays.map((e) => [e.id, e]));
const currentPath = Astro.url.pathname;

const navLinks = [
  { num: '01', href: '/gallery', label: 'Gallery', match: '/gallery' },
  { num: '02', href: '/work', label: 'Field', match: '/work', hasChildren: true },
  { num: '03', href: '/blog', label: 'Journal', match: '/blog' },
  { num: '04', href: '/about', label: 'About', match: '/about' },
];
---

<header class:list={['header', minimal && 'header--minimal']}>
  <div class="header-inner">
    <div class="header-left">
      <button
        class="menu-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>

    {!minimal && (
      <a href="/" class="logo" aria-label="Home">
        Corbin Heist
      </a>
    )}

    {!minimal ? (
      <div class="header-right">
        <ThemeToggle />
      </div>
    ) : (
      <div class="header-right" />
    )}
  </div>
</header>

<!-- Dropdown backdrop -->
<div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>

<!-- Dropdown sheet -->
<nav class="nav-dropdown" data-nav-dropdown aria-hidden="true" aria-label="Main navigation">
  <ul class="nav-list">
    {navLinks.map((link) => {
      const isActive = link.match === '/work'
        ? currentPath === '/work' || currentPath === '/work/'
        : currentPath.startsWith(link.match);

      return (
        <li class="nav-item">
          {link.hasChildren ? (
            <button
              class:list={['nav-link', { 'nav-link--active': isActive || currentPath.startsWith('/work/') }]}
              type="button"
              data-nav-accordion
            >
              <span class="nav-link__num">{link.num}</span>
              <span class="nav-link__label">{link.label}</span>
              <span class="nav-link__chevron">&#x203A;</span>
            </button>
          ) : (
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': isActive }]}
            >
              <span class="nav-link__num">{link.num}</span>
              <span class="nav-link__label">{link.label}</span>
            </a>
          )}

          {link.hasChildren && (
            <div class="nav-accordion" data-nav-accordion-panel>
              {/* Work index link */}
              <a
                href="/work"
                class:list={['nav-sub', { 'nav-sub--active': currentPath === '/work' || currentPath === '/work/' }]}
              >All collections</a>
              {collections.map((c) => {
                const essayIds = c.data.essays ?? [];
                return (
                  <>
                    <a
                      href={`/work/${c.id}`}
                      class:list={['nav-sub', { 'nav-sub--active': currentPath.startsWith(`/work/${c.id}`) }]}
                    >{c.data.title}</a>
                    {essayIds.map((essayId) => {
                      const essay = essayById.get(essayId);
                      if (!essay) return null;
                      const slug = essay.id.replace(new RegExp(`^${c.id}-`), '');
                      const href = `/work/${c.id}/${slug}`;
                      return (
                        <a
                          href={href}
                          class:list={['nav-sub nav-sub--essay', { 'nav-sub--active': currentPath === href || currentPath === `${href}/` }]}
                        >{essay.data.title}</a>
                      );
                    })}
                  </>
                );
              })}
            </div>
          )}
        </li>
      );
    })}
  </ul>

  <div class="nav-footer">
    <ThemeToggle />
    <span class="nav-footer__label">Toggle theme</span>
  </div>
</nav>

<script>
  function initNavDropdown() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const dropdown = document.querySelector<HTMLElement>('[data-nav-dropdown]');
    const backdrop = document.querySelector<HTMLElement>('[data-nav-backdrop]');
    if (!toggle || !dropdown || !backdrop) return;

    const focusableSelector = 'a[href], button:not([disabled])';

    function openMenu() {
      toggle!.setAttribute('aria-expanded', 'true');
      dropdown!.setAttribute('aria-hidden', 'false');
      backdrop!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      // Focus first link after slide animation
      setTimeout(() => {
        const firstLink = dropdown!.querySelector<HTMLElement>(focusableSelector);
        firstLink?.focus();
      }, 350);
    }

    function closeMenu() {
      toggle!.setAttribute('aria-expanded', 'false');
      dropdown!.setAttribute('aria-hidden', 'true');
      backdrop!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      toggle!.focus();
    }

    function isOpen() {
      return toggle!.getAttribute('aria-expanded') === 'true';
    }

    toggle.addEventListener('click', () => {
      isOpen() ? closeMenu() : openMenu();
    });

    // Close on backdrop click
    backdrop.addEventListener('click', closeMenu);

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;

      if (e.key === 'Escape') {
        closeMenu();
        return;
      }

      // Focus trap
      if (e.key === 'Tab') {
        const focusable = [
          toggle!,
          ...Array.from(dropdown!.querySelectorAll<HTMLElement>(focusableSelector)),
        ];
        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Close on nav link click
    dropdown.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Work accordion toggle
    const accordionBtn = dropdown.querySelector<HTMLElement>('[data-nav-accordion]');
    const accordionPanel = dropdown.querySelector<HTMLElement>('[data-nav-accordion-panel]');

    if (accordionBtn && accordionPanel) {
      accordionBtn.addEventListener('click', () => {
        const expanded = accordionPanel.classList.toggle('nav-accordion--open');
        accordionBtn.classList.toggle('nav-link--expanded', expanded);
      });

      // Auto-expand if currently on a work sub-page
      const onWorkPage = window.location.pathname.startsWith('/work/');
      if (onWorkPage) {
        accordionPanel.classList.add('nav-accordion--open');
        accordionBtn.classList.add('nav-link--expanded');
      }
    }
  }

  // Handle Astro page transitions
  document.addEventListener('astro:before-preparation', () => {
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    if (toggle?.getAttribute('aria-expanded') === 'true') {
      toggle.setAttribute('aria-expanded', 'false');
      document.querySelector<HTMLElement>('[data-nav-dropdown]')?.setAttribute('aria-hidden', 'true');
      document.querySelector<HTMLElement>('[data-nav-backdrop]')?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });

  document.addEventListener('astro:page-load', initNavDropdown);
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: calc(var(--z-overlay) + 2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-bg) 80%, transparent);
    border-bottom: 1px solid var(--color-border);
  }

  /* Hide header on desktop — side rail handles navigation */
  @media (min-width: 1024px) {
    .header:not(.header--minimal) {
      display: none;
    }
  }

  :global([data-theme='light']) .header {
    background: color-mix(in srgb, var(--color-bg) 80%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--container-padding);
  }

  .header-left,
  .header-right {
    display: flex;
    align-items: center;
    min-width: 40px;
  }

  .header-right {
    justify-content: flex-end;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: calc(var(--text-xl) * 1.15);
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
  }

  /* Minimal mode — essay pages: hamburger only, transparent */
  .header--minimal {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
  }

  .header--minimal .header-inner {
    justify-content: flex-start;
  }

  /* Hamburger button */
  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
  }

  .menu-bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--color-text);
    transition: transform var(--duration-normal) var(--ease-out-quart);
  }

  .menu-toggle[aria-expanded='true'] .menu-bar:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] .menu-bar:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ── Backdrop ── */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: rgba(16, 15, 15, 0.4);
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms ease;
  }

  .nav-backdrop[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  :global([data-theme='light']) .nav-backdrop {
    background: rgba(242, 240, 229, 0.3);
  }

  /* ── Dropdown sheet ── */
  .nav-dropdown {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: calc(var(--z-overlay) + 1);
    padding-top: 56px; /* header bar height */
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--color-border);
    max-height: 85dvh;
    overflow-y: auto;
    overscroll-behavior: contain;

    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 350ms var(--ease-out-quart),
      opacity 350ms var(--ease-out-quart);
  }

  .nav-dropdown[aria-hidden='false'] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Faster close */
  .nav-dropdown[aria-hidden='true'] {
    transition-duration: 250ms;
  }

  :global([data-theme='light']) .nav-dropdown {
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
  }

  /* Hide on desktop */
  @media (min-width: 1024px) {
    .nav-dropdown:not(:has(~ .header--minimal)),
    .nav-backdrop {
      display: none;
    }
  }

  /* ── Nav list ── */
  .nav-list {
    list-style: none;
    margin: 0;
    padding: var(--space-sm) 0;
  }

  .nav-item {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .nav-item:last-child {
    border-bottom: none;
  }

  /* ── Nav link (shared for <a> and <button>) ── */
  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
    padding: 14px var(--container-padding);
    min-height: 48px;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text);
    cursor: pointer;
    text-align: left;
    transition: background var(--duration-fast) ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    background: var(--color-surface);
  }

  .nav-link--active {
    color: var(--color-accent);
  }

  .nav-link__num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    min-width: 20px;
  }

  .nav-link--active .nav-link__num {
    color: var(--color-accent);
  }

  .nav-link__label {
    flex: 1;
  }

  .nav-link__chevron {
    font-size: 18px;
    color: var(--color-text-faint);
    transition: transform var(--duration-normal) var(--ease-out-quart);
    line-height: 1;
  }

  .nav-link--expanded .nav-link__chevron {
    transform: rotate(90deg);
  }

  /* ── Accordion panel ── */
  .nav-accordion {
    max-height: 0;
    overflow: hidden;
    transition: max-height 350ms var(--ease-out-quart);
    background: var(--color-surface);
  }

  .nav-accordion--open {
    max-height: 600px;
  }

  .nav-sub {
    display: block;
    padding: 10px var(--container-padding) 10px calc(var(--container-padding) + 32px);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
  }

  .nav-sub:hover,
  .nav-sub:focus-visible {
    color: var(--color-accent);
  }

  .nav-sub--active {
    color: var(--color-accent);
  }

  .nav-sub--essay {
    padding-left: calc(var(--container-padding) + 48px);
    font-size: var(--text-sm);
    color: var(--color-text-faint);
  }

  .nav-sub--essay.nav-sub--active {
    color: var(--color-accent);
  }

  /* ── Footer (theme toggle) ── */
  .nav-footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--container-padding) var(--space-md);
    border-top: 1px solid var(--color-border-subtle);
  }

  .nav-footer__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .nav-dropdown {
      transition: none;
    }

    .nav-backdrop {
      transition: none;
    }

    .nav-accordion {
      transition: none;
    }
  }
</style>
