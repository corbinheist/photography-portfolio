---
/**
 * Nomads of Djebel Saghro — Photo Essay (Dossier 011)
 *
 * A day with the Ait Atta: arrival, tea, bread, herders, and firelight
 * in Morocco's Djebel Saghro massif. November 2025.
 */
import ProjectLayout from '@layouts/ProjectLayout.astro';
import PhotoLightbox from '@components/photo/PhotoLightbox.astro';
import EssaySlideHero from '@components/essay/EssaySlideHero.astro';
import EssaySlideFullBleed from '@components/essay/EssaySlideFullBleed.astro';
import EssaySlideImageText from '@components/essay/EssaySlideImageText.astro';
import EssaySlideDiptych from '@components/essay/EssaySlideDiptych.astro';
import EssaySlideTriptych from '@components/essay/EssaySlideTriptych.astro';
import EssaySlideText from '@components/essay/EssaySlideText.astro';
import EssaySlideFlow from '@components/essay/EssaySlideFlow.astro';
import EssaySlideQuote from '@components/essay/EssaySlideQuote.astro';
import EssayDivider from '@components/essay/EssayDivider.astro';
import EssaySlidePullQuoteFB from '@components/essay/EssaySlidePullQuoteFB.astro';
import EssaySlideTimeline from '@components/essay/EssaySlideTimeline.astro';
import EssaySlideContactSheet from '@components/essay/EssaySlideContactSheet.astro';
import EssaySlideGear from '@components/essay/EssaySlideGear.astro';
import EssaySlideRelated from '@components/essay/EssaySlideRelated.astro';
import EssaySlidePinnedCaption from '@components/essay/EssaySlidePinnedCaption.astro';
import EssaySlideProseColumns from '@components/essay/EssaySlideProseColumns.astro';
import EssaySlideMapInset from '@components/essay/EssaySlideMapInset.astro';
import moroccoRegions from '@data/maps/morocco-regions.json';
import { getEntry } from 'astro:content';

const essay = await getEntry('essays', 'morocco-nomads-essay');
const photos = essay!.data.photos;
---

<ProjectLayout
  title="Nomads of Djebel Saghro"
  description="A day with the Ait Atta — tea, bread, herds, and firelight in Morocco's volcanic highlands."
  dossier={{ num: '011', label: 'NOMADS', totalFrames: 26 }}
  mapLayout="hidden"
  mapActiveCollection="morocco"
>

  <!-- ======= HERO ======= -->

  <!-- 1. Hero — The road in -->
  <EssaySlideHero
    url={photos[0].url}
    width={photos[0].width}
    height={photos[0].height}
    lqip={photos[0].lqip}
    alt={photos[0].title}
    lightboxIndex={0}
    dossierNum="011"
    sequenceNum="N° 01"
    overline="Djebel Saghro · Anti-Atlas · Morocco"
    title="Nomads of Djebel Saghro"
    deck="A day with the Ait Atta — tea, bread, herds, and firelight in Morocco's volcanic highlands."
    manifest={{
      region: 'Anti-Atlas',
      coords: "31°16′N 5°59′W",
      elev: '2,100 m',
      date: 'NOV 2025',
      frames: '35',
    }}
  />

  <!-- 2. Opening text -->
  <EssaySlideText align="center">
    <p class="overline">Djebel Saghro &middot; Anti-Atlas &middot; 31&deg;16&prime;N 5&deg;59&prime;W</p>
    <h2>Where the road ends, the camps begin</h2>
    <p>
      South of Ouarzazate, the paved road gives way to gravel, then to ruts cut
      into volcanic rock. The Saghro massif rises from the desert floor&mdash;a plateau
      of black pinnacles and dry riverbeds where the Ait Atta have kept their herds
      for centuries. We drove in from the north, dust hanging behind the truck in
      a slow column that took minutes to settle.
    </p>
  </EssaySlideText>

  <!-- Map inset — location context -->
  <EssaySlideMapInset
    heading="Anti-Atlas massif, southern Morocco"
    description="The Djebel Saghro is a volcanic plateau rising between the High Atlas and the Sahara — black basalt pinnacles, dry riverbeds, and seasonal camps of the Ait Atta nomads."
    metadata={[
      { label: 'Region', value: 'Anti-Atlas' },
      { label: 'Coords', value: "31°16′N 5°59′W" },
      { label: 'Elevation', value: '2,100 m' },
      { label: 'Dates', value: 'November 2025' },
    ]}
    center={[-5.85, 31.25]}
    zoom={7.5}
    collectionId="morocco"
    regions={moroccoRegions as any}
    markers={[
      { lng: -5.85, lat: 31.25, label: 'Djebel Saghro', num: '01' },
    ]}
  />

  <!-- ======= I. ARRIVAL & CAMP ======= -->

  <EssayDivider num="01" label="I · ARRIVAL & CAMP" />

  <!-- 3. Tea preparation — image + text -->
  <EssaySlideImageText
    url={photos[1].url}
    width={photos[1].width}
    height={photos[1].height}
    lqip={photos[1].lqip}
    alt={photos[1].title}
    lightboxIndex={1}
    frameSlide
  >
    <h3>The Tea Ritual</h3>
    <p>
      At the first camp, tea was already underway before we'd shut the engine off.
      The kettle sat on a triangle of stones over scrub-brush coals, and the man
      crouching beside it was measuring sugar into a Nestl&eacute; tin that had
      clearly served this purpose for years.
    </p>
    <p>
      Three pours. The first is for the tea, the second for the sugar, the third
      for the mint. Each pour from waist height, a thin amber arc into the glass.
      We drank it standing, burning our fingers on the glasses.
    </p>
  </EssaySlideImageText>

  <!-- 4. Pouring tea — full bleed portrait -->
  <EssaySlideFullBleed
    url={photos[2].url}
    width={photos[2].width}
    height={photos[2].height}
    lqip={photos[2].lqip}
    alt={photos[2].title}
    lightboxIndex={2}
    fit="contain"
    frameSlide
  />

  <!-- 5. Details diptych — sugar scoop + flour hands -->
  <EssaySlideDiptych
    photos={[
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 6. Bread making — image + text (flipped) -->
  <EssaySlideImageText
    url={photos[5].url}
    width={photos[5].width}
    height={photos[5].height}
    lqip={photos[5].lqip}
    alt={photos[5].title}
    lightboxIndex={5}
    flip
    frameSlide
  >
    <h3>Bread in the Dark</h3>
    <p>
      Inside the felt tent, a woman was making bread. The light came from a single
      gap in the canvas above, falling on the dough and on her hands as she worked it
      flat against a cloth laid on the ground. Two children sat behind her, watching
      us watch her.
    </p>
    <p>
      The bread would go into the ashes of the outdoor fire, buried under coals and
      pulled out twenty minutes later with a crust like cracked earth. It tasted like
      smoke and wheat and something chalky from the ash.
    </p>
  </EssaySlideImageText>

  <!-- 7. Portraits diptych — tea maker + bread sharer -->
  <EssaySlideDiptych
    photos={[
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- Pull quote — tea maker -->
  <EssaySlidePullQuoteFB
    url={photos[6].url}
    width={photos[6].width}
    height={photos[6].height}
    lqip={photos[6].lqip}
    alt={photos[6].title}
    lightboxIndex={6}
    text="The first pour is for the tea, the second for the sugar, the third for the mint."
    attribution="Field note · Day 1"
    location="Camp I · 31°16′N"
    dossierNum="011"
  />

  <!-- 8. Bread oven fire — full bleed -->
  <EssaySlideFullBleed
    url={photos[8].url}
    width={photos[8].width}
    height={photos[8].height}
    lqip={photos[8].lqip}
    alt={photos[8].title}
    lightboxIndex={8}
    captionTitle={photos[8].title}
    frameSlide
  />

  <!-- ======= II. THE HERDERS ======= -->

  <EssayDivider num="02" label="II · THE HERDERS" />

  <!-- 9. Transition prose -->
  <EssaySlideFlow>
    <h2>The Herders of Saghro</h2>
    <p>
      After tea, we walked out from the camp toward the pinnacles. The landscape opened
      up in every direction&mdash;flat gravel plains broken by columns of eroded volcanic
      rock, black basalt worn into spires and doorways by wind and rain.
    </p>
    <p>
      The herders appeared gradually. First a distant scatter of sheep on a hillside,
      then the figure standing above them in a striped djellaba and white turban, one
      hand on a stick, the other shielding his eyes. They moved their flocks between
      the pinnacles at a pace set entirely by the animals. There was no urgency.
    </p>
  </EssaySlideFlow>

  <!-- 10. Herder with flock — full bleed portrait -->
  <EssaySlideFullBleed
    url={photos[9].url}
    width={photos[9].width}
    height={photos[9].height}
    lqip={photos[9].lqip}
    alt={photos[9].title}
    lightboxIndex={9}
    fit="contain"
    frameSlide
  />

  <!-- 11. Herder with kid — image + text -->
  <EssaySlideImageText
    url={photos[10].url}
    width={photos[10].width}
    height={photos[10].height}
    lqip={photos[10].lqip}
    alt={photos[10].title}
    lightboxIndex={10}
    frameSlide
  >
    <h3>The Flock</h3>
    <p>
      He held the kid the way you'd hold something both fragile and routine&mdash;one arm
      under the belly, the other free. The flock numbered maybe sixty head, mostly sheep
      with a handful of goats mixed in, and he knew them individually. A ewe with a torn
      ear. A black goat that always wandered left.
    </p>
    <p>
      The pinnacles behind him looked like a city from a distance. Up close they were
      just rock. The herders paid them no attention. They were furniture.
    </p>
  </EssaySlideImageText>

  <!-- 12. Two herder portraits diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[11], alt: photos[11].title, lightboxIndex: 11 },
      { ...photos[12], alt: photos[12].title, lightboxIndex: 12 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- Timeline — a day with the herders -->
  <EssaySlideTimeline
    heading="A day in the field."
    lead="The rhythm of life in the Saghro follows the sun and the flock."
    entries={[
      { time: '05:40', label: 'First light', note: 'Sun hits the eastern pinnacles. The camp stirs.' },
      { time: '07:10', label: 'Tea and bread', note: 'Kettle on the coals, bread in the ashes.' },
      { time: '09:30', label: 'Herds out', note: 'Sheep and goats move toward the western pasture.' },
      { time: '13:00', label: 'Shade and rest', note: 'Too hot to move. Shelter under rock overhangs.', active: true },
      { time: '17:45', label: 'Water run', note: 'Forty minutes to the nearest source and back.' },
      { time: '19:20', label: 'Fire and again', note: 'Scrub brush, coals, kettle. The cycle resets.' },
    ]}
  />

  <!-- 13. Pinnacles landscape — full bleed -->
  <EssaySlideFullBleed
    url={photos[13].url}
    width={photos[13].width}
    height={photos[13].height}
    lqip={photos[13].lqip}
    alt={photos[13].title}
    lightboxIndex={13}
    captionTitle={photos[13].title}
    captionMeta="35mm &middot; f/6.3 &middot; 1/320s"
    frameSlide
  />

  <!-- 14. Two herders sitting diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[14], alt: photos[14].title, lightboxIndex: 14 },
      { ...photos[15], alt: photos[15].title, lightboxIndex: 15 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 15. Herder carrying water — image + text (flipped) -->
  <EssaySlideImageText
    url={photos[16].url}
    width={photos[16].width}
    height={photos[16].height}
    lqip={photos[16].lqip}
    alt={photos[16].title}
    lightboxIndex={16}
    flip
    frameSlide
  >
    <h3>Between Water and Pasture</h3>
    <p>
      The nearest water source was a forty-minute walk. He carried it in a red jerry
      can slung over one shoulder, the djellaba bunched around the strap. The route
      hadn't changed in his lifetime, or in his father's.
    </p>
    <p>
      In the Saghro, water determines everything: where you camp, how long you stay,
      which direction you move next.
    </p>
  </EssaySlideImageText>

  <!-- 16. Three wide herding landscapes — triptych -->
  <EssaySlideTriptych
    photos={[
      { ...photos[17], alt: photos[17].title, lightboxIndex: 17 },
      { ...photos[18], alt: photos[18].title, lightboxIndex: 18 },
      { ...photos[19], alt: photos[19].title, lightboxIndex: 19 },
    ]}
    gap="tight"
  />

  <!-- 17. Two herders walking — full bleed portrait -->
  <EssaySlideFullBleed
    url={photos[20].url}
    width={photos[20].width}
    height={photos[20].height}
    lqip={photos[20].lqip}
    alt={photos[20].title}
    lightboxIndex={20}
    fit="contain"
    frameSlide
  />

  <!-- 18. Flock at mesa sunset — full bleed landscape (transition to dusk) -->
  <EssaySlideFullBleed
    url={photos[21].url}
    width={photos[21].width}
    height={photos[21].height}
    lqip={photos[21].lqip}
    alt={photos[21].title}
    lightboxIndex={21}
    frameSlide
  />

  <!-- ======= III. DUSK & FIRELIGHT ======= -->

  <EssayDivider num="03" label="III · DUSK & FIRELIGHT" />

  <!-- 19. Pull quote -->
  <EssaySlideQuote
    text="In the Saghro, water determines everything: where you camp, how long you stay, which direction you move next."
  />

  <!-- 20. Transition text -->
  <EssaySlideText align="center">
    <h2>When the light goes</h2>
    <p>
      The sun drops behind the western mesa and the
      temperature follows it down&mdash;ten degrees in twenty minutes. The herders
      pulled their hoods up and gathered scrub brush, and the first fire was lit
      before the sky had finished turning.
    </p>
  </EssaySlideText>

  <!-- 20. Campfire below cliffs — full bleed portrait -->
  <EssaySlideFullBleed
    url={photos[22].url}
    width={photos[22].width}
    height={photos[22].height}
    lqip={photos[22].lqip}
    alt={photos[22].title}
    lightboxIndex={22}
    fit="contain"
    frameSlide
  />

  <!-- 21. Two campfire scenes diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[23], alt: photos[23].title, lightboxIndex: 23 },
      { ...photos[24], alt: photos[24].title, lightboxIndex: 24 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 22. Fire tender — image + text -->
  <EssaySlideImageText
    url={photos[25].url}
    width={photos[25].width}
    height={photos[25].height}
    lqip={photos[25].lqip}
    alt={photos[25].title}
    lightboxIndex={25}
    frameSlide
  >
    <h3>Fire and Tea Again</h3>
    <p>
      The fire served two purposes: warmth and tea. The kettle went on first, balanced
      on the same arrangement of stones, and the scrub brush burned hot and fast. He
      fed it in handfuls, leaning forward to blow on the coals when the flame dropped,
      his djellaba hood pulled low against the wind that came up the valley after dark.
    </p>
    <p>
      Nobody spoke much. The fire crackled. The kettle ticked as it heated. Somewhere
      out in the dark, the sheep shifted and settled.
    </p>
  </EssaySlideImageText>

  <!-- 23. Kettles diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[26], alt: photos[26].title, lightboxIndex: 26 },
      { ...photos[27], alt: photos[27].title, lightboxIndex: 27 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 24. Campfire among pinnacles — full bleed landscape -->
  <EssaySlideFullBleed
    url={photos[28].url}
    width={photos[28].width}
    height={photos[28].height}
    lqip={photos[28].lqip}
    alt={photos[28].title}
    lightboxIndex={28}
    frameSlide
  />

  <!-- 25. Campfire + dusk landscape diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[29], alt: photos[29].title, lightboxIndex: 29 },
      { ...photos[30], alt: photos[30].title, lightboxIndex: 30 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 26. Two at fire wide — full bleed landscape -->
  <EssaySlideFullBleed
    url={photos[31].url}
    width={photos[31].width}
    height={photos[31].height}
    lqip={photos[31].lqip}
    alt={photos[31].title}
    lightboxIndex={31}
    frameSlide
  />

  <!-- 27. Firelight portrait — image + text (flipped) -->
  <EssaySlideImageText
    url={photos[32].url}
    width={photos[32].width}
    height={photos[32].height}
    lqip={photos[32].lqip}
    alt={photos[32].title}
    lightboxIndex={32}
    flip
    frameSlide
  >
    <h3>The Last Tea</h3>
    <p>
      By full dark, the cliffs were gone, the pinnacles were gone, the flock was
      a sound in the darkness. Nothing left but the fire and the faces around it
      and the kettle making its third round of the evening.
    </p>
    <p>
      He poured the tea the same way he had that afternoon&mdash;high arc, steady
      hand, the amber catching the light of the coals instead of the sun. The
      gesture was identical. The light had changed completely.
    </p>
  </EssaySlideImageText>

  <!-- 28. Embers close-up — full bleed portrait -->
  <EssaySlideFullBleed
    url={photos[33].url}
    width={photos[33].width}
    height={photos[33].height}
    lqip={photos[33].lqip}
    alt={photos[33].title}
    lightboxIndex={33}
    fit="contain"
    frameSlide
  />

  <!-- 29. Closing — man by dying embers -->
  <EssaySlideFullBleed
    url={photos[34].url}
    width={photos[34].width}
    height={photos[34].height}
    lqip={photos[34].lqip}
    alt={photos[34].title}
    lightboxIndex={34}
    fit="contain"
    frameSlide
  />

  <!-- ======= APPENDIX ======= -->

  <!-- Contact sheet — select frames -->
  <EssaySlideContactSheet
    heading="DOSSIER 011 · PROOF SHEET"
    caption="Selected frames."
    photos={[
      { url: photos[0].url, width: photos[0].width, height: photos[0].height, lqip: photos[0].lqip, alt: photos[0].title, lightboxIndex: 0 },
      { url: photos[2].url, width: photos[2].width, height: photos[2].height, lqip: photos[2].lqip, alt: photos[2].title, lightboxIndex: 2 },
      { url: photos[6].url, width: photos[6].width, height: photos[6].height, lqip: photos[6].lqip, alt: photos[6].title, lightboxIndex: 6 },
      { url: photos[9].url, width: photos[9].width, height: photos[9].height, lqip: photos[9].lqip, alt: photos[9].title, lightboxIndex: 9 },
      { url: photos[11].url, width: photos[11].width, height: photos[11].height, lqip: photos[11].lqip, alt: photos[11].title, lightboxIndex: 11 },
      { url: photos[13].url, width: photos[13].width, height: photos[13].height, lqip: photos[13].lqip, alt: photos[13].title, lightboxIndex: 13 },
      { url: photos[20].url, width: photos[20].width, height: photos[20].height, lqip: photos[20].lqip, alt: photos[20].title, lightboxIndex: 20 },
      { url: photos[22].url, width: photos[22].width, height: photos[22].height, lqip: photos[22].lqip, alt: photos[22].title, lightboxIndex: 22 },
      { url: photos[25].url, width: photos[25].width, height: photos[25].height, lqip: photos[25].lqip, alt: photos[25].title, lightboxIndex: 25 },
      { url: photos[28].url, width: photos[28].width, height: photos[28].height, lqip: photos[28].lqip, alt: photos[28].title, lightboxIndex: 28 },
      { url: photos[32].url, width: photos[32].width, height: photos[32].height, lqip: photos[32].lqip, alt: photos[32].title, lightboxIndex: 32 },
      { url: photos[34].url, width: photos[34].width, height: photos[34].height, lqip: photos[34].lqip, alt: photos[34].title, lightboxIndex: 34 },
    ]}
    footerLeft="HEIST.STUDIO / FIELD"
    footerRight="35mm + 50mm · NOV 2025"
  />

  <!-- Prose columns — what the fire does -->
  <EssaySlideProseColumns heading="What the fire does." leftLabel="WARMTH" rightLabel="TEA">
    <p slot="left">
      The scrub brush of the Saghro burns hot and fast. It crackles like rifle shots
      in the silence. The herders feed it in steady handfuls, leaning forward to blow
      on the coals when the flame drops. The warmth pushes back the cold that rolls
      down from the mesa after sunset, ten degrees gone in twenty minutes. Without the
      fire there is only the dark and the wind.
    </p>
    <p slot="right">
      The kettle goes on first, balanced on the same three stones, and by the time
      the tea is poured the fire has done its work twice over. The amber arc from pot
      to glass catches the light of the coals instead of the sun, and the gesture is
      identical to the one made that morning. The ritual holds. The fire is the axis
      around which the day turns.
    </p>
  </EssaySlideProseColumns>

  <!-- Gear manifest -->
  <EssaySlideGear
    heading="Kit manifest."
    lead="Two bodies, three lenses, and a tripod that mostly stayed in the bag."
    items={[
      { name: 'Canon EOS R5 Mark II', description: 'Primary body. 45MP, fast autofocus in low light. 30 of 35 frames.', usage: '30 FRAMES' },
      { name: 'Canon EOS R5', description: 'Secondary body. Paired with the 70-200mm for reach.', usage: '5 FRAMES' },
      { name: 'RF 50mm f/1.2L USM', description: 'Primary lens. Wide open for firelight work, stopped down for daylight.', usage: 'PRIMARY' },
      { name: 'RF 35mm f/1.4L VCM', description: 'Secondary wide. Used for campfire scenes and landscapes.', usage: 'SECONDARY' },
      { name: 'RF 70-200mm f/2.8L IS USM', description: 'Telephoto for herders at distance. Compressed the pinnacles.', usage: 'TELEPHOTO' },
      { name: 'Peak Design Travel Tripod', description: 'Carbon fiber. Carried every day, used twice.', usage: 'RARELY' },
    ]}
    footerLeft="DOSSIER 011"
    footerRight="TOTAL: 35 FRAMES"
  />

  <!-- 30. Related dossiers -->
  <EssaySlideRelated
    featured={{
      title: 'Ksar Tamnougalt',
      slug: '/work/morocco/ksar-essay',
      description: 'A fortified village in the Draa Valley — mud walls, palm groves, and the memory of the caravan trade.',
      location: 'Draa Valley · Morocco',
      dossierLabel: 'N° 02',
      coverUrl: 'https://heist-studio.sfo3.cdn.digitaloceanspaces.com/photos/heist-ksar-essay-001-cnh_3628',
      coverWidth: 8192,
      coverHeight: 5464,
      coverLqip: 'data:image/webp;base64,UklGRm4AAABXRUJQVlA4IGIAAADQAwCdASoUAA0APzmGulOvKKWisAgB4CcJZgCdABVMf5fTxeZtJAAA/Sg8oHK1A2k1PN6bRmq/0twRB0hsT7ynLd+uVaEXUfAdpaxNpMuQbcf6TMUZQH8Q6jGWfJQDFIAAAA==',
    }}
    allDossiersHref="/work/morocco"
  />

  <PhotoLightbox photos={photos} />
</ProjectLayout>
