---

<ProjectLayout
  title="The Bougmez Underfoot"
  description="One day in Morocco's High Atlas — gorge, pass, and darkness. A Wise Ultra Running assignment."
  dossier={{ num: '013', label: 'WISE', totalFrames: 24 }}
>

  <!-- 1. Hero — runner trailing mule into gorge -->
  <EssaySlideHero
    url={photos[0].url}
    width={photos[0].width}
    height={photos[0].height}
    lqip={photos[0].lqip}
    alt={photos[0].title}
    lightboxIndex={0}
    dossierNum="013"
    sequenceNum="N° 03"
    overline="A&iuml;t Bougmez &middot; High Atlas &middot; Morocco"
    title="The Bougmez Underfoot"
    deck="One day, three locations, two runners, a mule guide. November 2025."
    manifest={{
      region: 'High Atlas',
      coords: "31°41′N 6°27′W",
      elev: '1,800 m',
      date: 'NOV 2025',
      frames: '24',
    }}
  />

  <!-- 2. Title card -->
  <EssaySlideText align="center">
    <p class="overline">A&iuml;t Bougmez &middot; High Atlas &middot; 31&deg;41&prime;N &ensp; 6&deg;27&prime;W</p>
    <h2>Dramatic / almost hostile</h2>
    <p>
      1200 Depart / 1400 Gorge / 1600 Pass / Tsiki &mdash; Sunset and Blue Hour.
      One day. Two runners. A mule guide named Bassouz.
    </p>
  </EssaySlideText>

  <!-- 3. Map inset -->
  <EssaySlideMapInset
    heading="High Atlas foothills, southern Morocco"
    description="A single day's route from the Aït Bougmez Valley through Happy Valley Gorge to the Tsiki Pass — three locations, gorge to summit, daylight to dark."
    metadata={[
      { label: 'Region', value: 'High Atlas' },
      { label: 'Coords', value: "31°41′N 6°27′W" },
      { label: 'Elevation', value: '1,800 m' },
      { label: 'Date', value: 'November 12, 2025' },
    ]}
    center={[-6.38, 31.61]}
    zoom={11}
    markers={[
      { lng: -6.45, lat: 31.68, label: 'Aït Bougmez Valley', num: '01' },
      { lng: -6.38, lat: 31.62, label: 'Happy Valley Gorge', num: '02' },
      { lng: -6.31, lat: 31.55, label: 'Tsiki Pass', num: '03' },
    ]}
    route={wiseRoute as any}
  />

  <!-- ======= I · THE GORGE ======= -->
  <EssayDivider num="01" label="I · THE GORGE" />

  <!-- 5. Village wide — image + text -->
  <EssaySlideImageText
    url={photos[1].url}
    width={photos[1].width}
    height={photos[1].height}
    lqip={photos[1].lqip}
    alt={photos[1].title}
    lightboxIndex={1}
    frameSlide
  >
    <h3>Happy Valley</h3>
    <p>
      [PROSE: arrival, the road giving way to dirt, "Happy Valley" by name.
      Donkeys loaded with hay, terraced fields stepping up toward the gorge mouth.]
    </p>
  </EssaySlideImageText>

  <!-- 6. Gorge mouth + Bassouz framed — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[2], alt: photos[2].title, lightboxIndex: 2 },
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 7. Bassouz portrait — pull quote -->
  <EssaySlidePullQuoteFB
    url={photos[4].url}
    width={photos[4].width}
    height={photos[4].height}
    lqip={photos[4].lqip}
    alt={photos[4].title}
    lightboxIndex={4}
    text="[FIELD NOTE: placeholder — short line about Bassouz]"
    attribution="Field note · Day 4"
    location="Happy Valley Gorge · 31°41′N"
    dossierNum="013"
  />

  <!-- 8. Bassouz riding, panning blur — full bleed -->
  <EssaySlideFullBleed
    url={photos[5].url}
    width={photos[5].width}
    height={photos[5].height}
    lqip={photos[5].lqip}
    alt={photos[5].title}
    lightboxIndex={5}
    fit="contain"
    frameSlide
  />

  <!-- 9. Two motion abstracts — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 10. Achmed at waterfall — full bleed -->
