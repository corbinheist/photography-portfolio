    url={photos[9].url}
    width={photos[9].width}
    height={photos[9].height}
    lqip={photos[9].lqip}
    alt={photos[9].title}
    lightboxIndex={9}
    fit="contain"
    frameSlide
  />

  <!-- ======= II · THE PASS ======= -->
  <EssayDivider num="02" label="II · THE PASS" />

  <!-- 13. HDR mountain valley — full bleed -->
  <EssaySlideFullBleed
    url={photos[10].url}
    width={photos[10].width}
    height={photos[10].height}
    lqip={photos[10].lqip}
    alt={photos[10].title}
    lightboxIndex={10}
