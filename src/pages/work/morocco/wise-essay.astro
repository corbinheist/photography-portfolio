  />

  <!-- 14. 50&stitch vertical pano — full bleed -->
  <EssaySlideFullBleed
    url={photos[11].url}
    width={photos[11].width}
    height={photos[11].height}
    lqip={photos[11].lqip}
    alt={photos[11].title}
    lightboxIndex={11}
    fit="contain"
    captionTitle="Desert Valley Road"
    captionMeta="50&amp;stitch vertical panorama"
    frameSlide
  />

  <!-- 15. Lone runner on switchback — image + text (flip) -->
  <EssaySlideImageText
    url={photos[12].url}
    width={photos[12].width}
    height={photos[12].height}
    lqip={photos[12].lqip}
    alt={photos[12].title}
    lightboxIndex={12}
    flip
    frameSlide
