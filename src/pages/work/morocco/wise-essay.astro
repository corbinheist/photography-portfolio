---
import ProjectLayout from '@layouts/ProjectLayout.astro';
import PhotoLightbox from '@components/photo/PhotoLightbox.astro';
import EssaySlideHero from '@components/essay/EssaySlideHero.astro';
import EssaySlideFullBleed from '@components/essay/EssaySlideFullBleed.astro';
import EssaySlideImageText from '@components/essay/EssaySlideImageText.astro';
import EssaySlideDiptych from '@components/essay/EssaySlideDiptych.astro';
import EssaySlideText from '@components/essay/EssaySlideText.astro';
import EssayDivider from '@components/essay/EssayDivider.astro';
import EssaySlidePullQuoteFB from '@components/essay/EssaySlidePullQuoteFB.astro';
import EssaySlideTimeline from '@components/essay/EssaySlideTimeline.astro';
import EssaySlideContactSheet from '@components/essay/EssaySlideContactSheet.astro';
import EssaySlideGear from '@components/essay/EssaySlideGear.astro';
import EssaySlideRelated from '@components/essay/EssaySlideRelated.astro';
import EssaySlidePinnedCaption from '@components/essay/EssaySlidePinnedCaption.astro';
import EssaySlideProseColumns from '@components/essay/EssaySlideProseColumns.astro';
import EssaySlideMapInset from '@components/essay/EssaySlideMapInset.astro';
import wiseRoute from '@data/maps/wise-route.json';
import { getEntry } from 'astro:content';

const essay = await getEntry('essays', 'morocco-wise-essay');
const photos = essay!.data.photos;
---

<ProjectLayout
  title="The Bougmez Underfoot"
  description="One day in Morocco's High Atlas — gorge, pass, and darkness. A Wise Ultra Running assignment."
  dossier={{ num: '013', label: 'WISE', totalFrames: 24 }}
  mapLayout="hidden"
  mapActiveCollection="morocco"
>

  <!-- 1. Hero — runner trailing mule into gorge -->
  <EssaySlideHero
    url={photos[0].url}
    width={photos[0].width}
    height={photos[0].height}
    lqip={photos[0].lqip}
    alt={photos[0].title}
    lightboxIndex={0}
    dossierNum="013"
    sequenceNum="N° 03"
    overline="A&iuml;t Bougmez &middot; High Atlas &middot; Morocco"
    title="The Bougmez Underfoot"
    deck="One day, three locations, two runners, a mule guide. November 2025."
    manifest={{
      region: 'High Atlas',
      coords: "31°41′N 6°27′W",
      elev: '1,800 m',
      date: 'NOV 2025',
      frames: '24',
    }}
  />

  <!-- 2. Title card -->
  <EssaySlideText align="center">
    <p class="overline">A&iuml;t Bougmez &middot; High Atlas &middot; 31&deg;41&prime;N &ensp; 6&deg;27&prime;W</p>
    <h2>Dramatic / almost hostile</h2>
    <p>
      1200 Depart / 1400 Gorge / 1600 Pass / Tsiki &mdash; Sunset and Blue Hour.
      One day. Two runners. A mule guide named Bassouz.
    </p>
  </EssaySlideText>

  <!-- 3. Map inset -->
  <EssaySlideMapInset
    heading="High Atlas foothills, southern Morocco"
    description="A single day's route from the Aït Bougmez Valley through Happy Valley Gorge to the Tsiki Pass — three locations, gorge to summit, daylight to dark."
    metadata={[
      { label: 'Region', value: 'High Atlas' },
      { label: 'Coords', value: "31°41′N 6°27′W" },
      { label: 'Elevation', value: '1,800 m' },
      { label: 'Date', value: 'November 12, 2025' },
    ]}
    center={[-6.38, 31.61]}
    zoom={11}
    collectionId="morocco"
    markers={[
      { lng: -6.45, lat: 31.68, label: 'Aït Bougmez Valley', num: '01' },
      { lng: -6.38, lat: 31.62, label: 'Happy Valley Gorge', num: '02' },
      { lng: -6.31, lat: 31.55, label: 'Tsiki Pass', num: '03' },
    ]}
    route={wiseRoute as any}
  />

  <!-- ======= I · THE GORGE ======= -->
  <EssayDivider num="01" label="I · THE GORGE" />

  <!-- 5. Village wide — image + text -->
  <EssaySlideImageText
    url={photos[1].url}
    width={photos[1].width}
    height={photos[1].height}
    lqip={photos[1].lqip}
    alt={photos[1].title}
    lightboxIndex={1}
    frameSlide
  >
    <h3>Happy Valley</h3>
    <p>
      [PROSE: arrival, the road giving way to dirt, "Happy Valley" by name.
      Donkeys loaded with hay, terraced fields stepping up toward the gorge mouth.]
    </p>
  </EssaySlideImageText>

  <!-- 6. Gorge mouth + Bassouz framed — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[2], alt: photos[2].title, lightboxIndex: 2 },
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 7. Bassouz portrait — pull quote -->
  <EssaySlidePullQuoteFB
    url={photos[4].url}
    width={photos[4].width}
    height={photos[4].height}
    lqip={photos[4].lqip}
    alt={photos[4].title}
    lightboxIndex={4}
    text="[FIELD NOTE: placeholder — short line about Bassouz]"
    attribution="Field note · Day 4"
    location="Happy Valley Gorge · 31°41′N"
    dossierNum="013"
  />

  <!-- 8. Bassouz riding, panning blur — full bleed -->
  <EssaySlideFullBleed
    url={photos[5].url}
    width={photos[5].width}
    height={photos[5].height}
    lqip={photos[5].lqip}
    alt={photos[5].title}
    lightboxIndex={5}
    fit="contain"
    frameSlide
  />

  <!-- 9. Two motion abstracts — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 10. Achmed at waterfall — full bleed -->
  <EssaySlideFullBleed
    url={photos[8].url}
    width={photos[8].width}
    height={photos[8].height}
    lqip={photos[8].lqip}
    alt={photos[8].title}
    lightboxIndex={8}
    fit="contain"
    frameSlide
  />

  <!-- 11. Vest from behind — full bleed (single brand frame) -->
  <EssaySlideFullBleed
    url={photos[9].url}
    width={photos[9].width}
    height={photos[9].height}
    lqip={photos[9].lqip}
    alt={photos[9].title}
    lightboxIndex={9}
    fit="contain"
    frameSlide
  />

  <!-- ======= II · THE PASS ======= -->
  <EssayDivider num="02" label="II · THE PASS" />

  <!-- 13. HDR mountain valley — full bleed -->
  <EssaySlideFullBleed
    url={photos[10].url}
    width={photos[10].width}
    height={photos[10].height}
    lqip={photos[10].lqip}
    alt={photos[10].title}
    lightboxIndex={10}
    frameSlide
  />

  <!-- 14. 50&stitch vertical pano — full bleed -->
  <EssaySlideFullBleed
    url={photos[11].url}
    width={photos[11].width}
    height={photos[11].height}
    lqip={photos[11].lqip}
    alt={photos[11].title}
    lightboxIndex={11}
    fit="contain"
    captionTitle="Desert Valley Road"
    captionMeta="50&amp;stitch vertical panorama"
    frameSlide
  />

  <!-- 15. Lone runner on switchback — image + text (flip) -->
  <EssaySlideImageText
    url={photos[12].url}
    width={photos[12].width}
    height={photos[12].height}
    lqip={photos[12].lqip}
    alt={photos[12].title}
    lightboxIndex={12}
    flip
    frameSlide
  >
    <h3>Scale</h3>
    <p>
      [PROSE: the country opens up after the gorge. Switchbacks cut into scree.
      The runner is a dot against the terrain.]
    </p>
  </EssaySlideImageText>

  <!-- 16. Two runners on switchback — pinned caption -->
  <EssaySlidePinnedCaption
    url={photos[13].url}
    width={photos[13].width}
    height={photos[13].height}
    lqip={photos[13].lqip}
    alt={photos[13].title}
    lightboxIndex={13}
    caption="Achmed and Aziza on the Tsiki switchback."
  />

  <!-- 17. Ridge silhouettes + scramble — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[14], alt: photos[14].title, lightboxIndex: 14 },
      { ...photos[15], alt: photos[15].title, lightboxIndex: 15 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 18. Profile motion run — full bleed -->
  <EssaySlideFullBleed
    url={photos[16].url}
    width={photos[16].width}
    height={photos[16].height}
    lqip={photos[16].lqip}
    alt={photos[16].title}
    lightboxIndex={16}
    frameSlide
  />

  <!-- 19. Two runners, dusk — image + text -->
  <EssaySlideImageText
    url={photos[17].url}
    width={photos[17].width}
    height={photos[17].height}
    lqip={photos[17].lqip}
    alt={photos[17].title}
    lightboxIndex={17}
    frameSlide
  >
    <h3>When the Light Drops</h3>
    <p>
      [PROSE: dusk. Ten degrees in twenty minutes. The pass changes character.]
    </p>
  </EssaySlideImageText>

  <!-- ======= III · INTO THE DARK ======= -->
  <EssayDivider num="03" label="III · INTO THE DARK" />

  <!-- 21. Wide ridge, fading light — full bleed -->
  <EssaySlideFullBleed
    url={photos[18].url}
    width={photos[18].width}
    height={photos[18].height}
    lqip={photos[18].lqip}
    alt={photos[18].title}
    lightboxIndex={18}
    frameSlide
  />

  <!-- 22. Headlamp portrait — pull quote -->
  <EssaySlidePullQuoteFB
    url={photos[19].url}
    width={photos[19].width}
    height={photos[19].height}
    lqip={photos[19].lqip}
    alt={photos[19].title}
    lightboxIndex={19}
    text="[PULL QUOTE: placeholder — the brief's 'dramatic / almost hostile' lands hardest here]"
    attribution="Field note · Day 4"
    location="Tsiki Pass · 31°41′N"
    dossierNum="013"
  />

  <!-- 23. Dusk flash pair — diptych -->
  <EssaySlideDiptych
    photos={[
      { ...photos[20], alt: photos[20].title, lightboxIndex: 20 },
      { ...photos[21], alt: photos[21].title, lightboxIndex: 21 },
    ]}
    gap="tight"
    frameSlide
  />

  <!-- 24. CLOSER — cleft of spires, flash starburst -->
  <EssaySlideFullBleed
    url={photos[22].url}
    width={photos[22].width}
    height={photos[22].height}
    lqip={photos[22].lqip}
    alt={photos[22].title}
    lightboxIndex={22}
    fit="contain"
    frameSlide
  />

  <!-- ======= APPENDIX ======= -->

  <!-- 25. Contact sheet -->
  <EssaySlideContactSheet
    heading="DOSSIER 013 · PROOF SHEET"
    caption="Selected frames."
    photos={[
      { url: photos[0].url, width: photos[0].width, height: photos[0].height, lqip: photos[0].lqip, alt: photos[0].title, lightboxIndex: 0 },
      { url: photos[4].url, width: photos[4].width, height: photos[4].height, lqip: photos[4].lqip, alt: photos[4].title, lightboxIndex: 4 },
      { url: photos[5].url, width: photos[5].width, height: photos[5].height, lqip: photos[5].lqip, alt: photos[5].title, lightboxIndex: 5 },
      { url: photos[8].url, width: photos[8].width, height: photos[8].height, lqip: photos[8].lqip, alt: photos[8].title, lightboxIndex: 8 },
      { url: photos[9].url, width: photos[9].width, height: photos[9].height, lqip: photos[9].lqip, alt: photos[9].title, lightboxIndex: 9 },
      { url: photos[10].url, width: photos[10].width, height: photos[10].height, lqip: photos[10].lqip, alt: photos[10].title, lightboxIndex: 10 },
      { url: photos[11].url, width: photos[11].width, height: photos[11].height, lqip: photos[11].lqip, alt: photos[11].title, lightboxIndex: 11 },
      { url: photos[12].url, width: photos[12].width, height: photos[12].height, lqip: photos[12].lqip, alt: photos[12].title, lightboxIndex: 12 },
      { url: photos[13].url, width: photos[13].width, height: photos[13].height, lqip: photos[13].lqip, alt: photos[13].title, lightboxIndex: 13 },
      { url: photos[19].url, width: photos[19].width, height: photos[19].height, lqip: photos[19].lqip, alt: photos[19].title, lightboxIndex: 19 },
      { url: photos[18].url, width: photos[18].width, height: photos[18].height, lqip: photos[18].lqip, alt: photos[18].title, lightboxIndex: 18 },
      { url: photos[22].url, width: photos[22].width, height: photos[22].height, lqip: photos[22].lqip, alt: photos[22].title, lightboxIndex: 22 },
    ]}
    footerLeft="HEIST.STUDIO / FIELD"
    footerRight="35mm + 50mm + 70-200mm · NOV 2025"
  />

  <!-- 26. Timeline -->
  <EssaySlideTimeline
    heading="One day."
    lead="Village to summit to dark."
    entries={[
      { time: '12:00', label: 'Depart', note: 'Leave the retreat. Drive south toward Aït Bougmez.' },
      { time: '14:00', label: 'Happy Valley Gorge', note: 'Bassouz meets the group. Mule, donkeys, slot canyon.' },
      { time: '15:00', label: 'AGA Mountain Field', note: 'Open terrain. Four frames. The weakest light of the day.' },
      { time: '16:00', label: 'Tsiki Pass', note: 'Switchbacks, scree, ridgeline. The country opens.', active: true },
      { time: '18:30', label: 'Sunset', note: 'Golden hour on the pass. Two-figure silhouettes.' },
      { time: '19:30', label: 'Blue hour', note: 'Speedlight and headlamp. Flash on rock spires.' },
      { time: '21:30', label: 'Return', note: 'Hammam and hot tub. The day is done.' },
    ]}
  />

  <!-- 27. Prose columns -->
  <EssaySlideProseColumns heading="What the country gives. What the light takes." leftLabel="THE COUNTRY" rightLabel="THE LIGHT">
    <p slot="left">
      [PROSE: what the gorge and pass give — natural framing, scale, the mule guide,
      the runners as figures in a landscape that doesn't care about them.]
    </p>
    <p slot="right">
      [PROSE: what the light takes — the compressed schedule, the lost detail shots,
      the gender gap, the techniques that happened by accident not by plan.]
    </p>
  </EssaySlideProseColumns>

  <!-- 28. Gear -->
  <EssaySlideGear
    heading="Kit manifest."
    lead="Two bodies, three lenses, one speedlight, and a Black Mist filter."
    items={[
      { name: 'Canon EOS R5 Mark II', description: 'Primary body. Daylight and dusk.', usage: 'PRIMARY' },
      { name: 'Canon EOS R5', description: 'Secondary body. Paired with the 70-200mm.', usage: 'SECONDARY' },
      { name: 'RF 50mm f/1.2L USM', description: 'Primary lens. Gorge portraits, motion blur, firelight.', usage: 'PRIMARY' },
      { name: 'RF 35mm f/1.4L VCM', description: 'Wide. Switchbacks, ridge silhouettes.', usage: 'SECONDARY' },
      { name: 'RF 70-200mm f/2.8L IS USM', description: 'Telephoto. Compressed the pass switchbacks.', usage: 'TELEPHOTO' },
      { name: 'Speedlight + Nanlite', description: 'Night flash work on the pass. Headlamp portraits.', usage: 'NIGHT' },
    ]}
    footerLeft="DOSSIER 013"
    footerRight="TOTAL: 24 FRAMES"
  />

  <!-- 29. Related -->
  <EssaySlideRelated
    featured={{
      title: 'Nomads of Djebel Saghro',
      slug: '/work/morocco/nomads-essay',
      description: 'A day with the Ait Atta — tea, bread, herds, and firelight in the volcanic highlands.',
      location: 'Anti-Atlas · 31°16′N',
      dossierLabel: 'N° 01 · DOSSIER 011',
      coverUrl: 'https://heist-studio.sfo3.cdn.digitaloceanspaces.com/photos/heist-_nomads-073-cnh_0912',
      coverWidth: 6916,
      coverHeight: 4613,
      coverLqip: 'data:image/webp;base64,UklGRlQAAABXRUJQVlA4IEgAAADQAwCdASoUAA0APzmIulQvKSWjMAgB4CcJYwC7AB6Gk0EQggGaVIAA94pOVoqQRFUpYGzbL827W9YrrdSIuLnnoSDnMcTPgAA=',
    }}
    allDossiersHref="/work/morocco"
  />

  <PhotoLightbox photos={photos} />
</ProjectLayout>
