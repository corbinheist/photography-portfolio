---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Photo from '@components/photo/Photo.astro';
import Map from '@components/Map.astro';

const collections = await getCollection('photoCollections');
const allPhotos = await getCollection('photos');

const sortedCollections = collections.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Load country-level outlines for the world map
const countryFiles = import.meta.glob<{ default: any }>('/src/data/maps/*-country.json', { eager: true });

// Build world markers + merged regions from all collections with map data
const collectionsWithMaps = sortedCollections.filter((c) => c.data.map);
let markerNum = 0;

const worldMarkers = collectionsWithMaps.map((c) => {
  markerNum++;
  return {
    label: c.data.title,
    lng: c.data.map!.center[0],
    lat: c.data.map!.center[1],
    num: String(markerNum).padStart(2, '0'),
    target: `/work/${c.id}`,
  };
});

// Merge all region GeoJSON into one FeatureCollection with matching nums
const worldRegionFeatures: any[] = [];
collectionsWithMaps.forEach((c, i) => {
  const countryFile = `/src/data/maps/${c.id}-country.json`;
  const data = countryFiles[countryFile]?.default;
  if (!data?.features) return;
  const num = String(i + 1).padStart(2, '0');
  for (const feat of data.features) {
    worldRegionFeatures.push({
      ...feat,
      properties: { ...feat.properties, num },
    });
  }
});

const worldRegions = worldRegionFeatures.length > 0
  ? { type: 'FeatureCollection' as const, features: worldRegionFeatures }
  : undefined;

function findPhoto(id: string) {
  return allPhotos.find((p) => p.id === id);
}

// Build film-roll data: photos from albums, interleaved across collections
const allAlbums = await getCollection('albums');
type FilmPhoto = {
  url: string; width: number; height: number; lqip: string;
  collectionId: string; collectionTitle: string; markerNum: string | null;
  albumUrl: string;
};

// Gather photos per collection (up to 6 each)
const photosByCollection: FilmPhoto[][] = [];
collectionsWithMaps.forEach((c, i) => {
  const num = String(i + 1).padStart(2, '0');
  const bucket: FilmPhoto[] = [];
  for (const albumId of c.data.albums) {
    const album = allAlbums.find((a) => a.id === albumId);
    if (!album || album.data.draft) continue;
    for (const photoId of album.data.photos.slice(0, 6)) {
      const photo = findPhoto(photoId);
      if (!photo) continue;
      bucket.push({
        url: photo.data.url, width: photo.data.width, height: photo.data.height,
        lqip: photo.data.lqip, collectionId: c.id, collectionTitle: c.data.title,
        markerNum: num, albumUrl: `/work/${c.id}/${albumId}`,
      });
    }
  }
  if (bucket.length) photosByCollection.push(bucket);
});

// Interleave round-robin: deal one from each collection in turn
const filmRollPhotos: FilmPhoto[] = [];
const maxLen = Math.max(...photosByCollection.map((b) => b.length), 0);
for (let round = 0; round < maxLen; round++) {
  for (const bucket of photosByCollection) {
    if (round < bucket.length) filmRollPhotos.push(bucket[round]);
  }
}
---

<PageLayout title="Work" description="Photography collections">
  {worldMarkers.length > 0 && (
    <div class="map-hero" id="map-hero">
      <div class="map-hero__map">
        <Map
          center={[10, 25]}
          zoom={1.8}
          markers={worldMarkers}
          regions={worldRegions}
          interactive={false}
          theme="default"
        />
      </div>
      {filmRollPhotos.length > 0 && (
        <div class="film-roll" data-film-roll>
          <div class="film-roll__track" data-film-track>
            {filmRollPhotos.map((p) => {
              const slug = p.url.split('/').pop() || '';
              const src = `${p.url}/${slug}-640.webp`;
              return (
                <a
                  href={p.albumUrl}
                  class="film-roll__frame"
                  data-marker-num={p.markerNum}
                  data-collection={p.collectionId}
                >
                  <img
                    src={src}
                    alt={p.collectionTitle}
                    class="film-roll__img"
                    loading="lazy"
                    decoding="async"
                    style={`background-image: url(${p.lqip}); background-size: cover;`}
                  />
                  <span class="film-roll__label">{p.collectionTitle}</span>
                </a>
              );
            })}
          </div>
          <div class="film-roll__edge film-roll__edge--left">
            <span class="film-roll__chevron">&laquo;</span>
          </div>
          <div class="film-roll__edge film-roll__edge--right">
            <span class="film-roll__chevron">&raquo;</span>
          </div>
        </div>
      )}
      <div class="map-hero__scroll-hint">
        <div class="map-hero__arrow"></div>
      </div>
    </div>
  )}

  <div class="work-content" id="work-content">
  <div class="work-header reveal">
    <h1>Work</h1>
  </div>
  <div class="work-grid-wrap">
    <div class="collections-grid stagger-children">
      {sortedCollections.map((collection) => {
        const cover = collection.data.coverPhoto ? findPhoto(collection.data.coverPhoto) : null;

        return (
          <a href={`/work/${collection.id}`} class="collection-card">
            {cover && (
              <div class="collection-image">
                <Photo
                  url={cover.data.url}
                  width={cover.data.width}
                  height={cover.data.height}
                  lqip={cover.data.lqip}
                  alt={collection.data.title}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
              </div>
            )}
            <div class="collection-info">
              <h2 class="collection-title">{collection.data.title}</h2>
              {collection.data.description && (
                <p class="collection-desc">{collection.data.description}</p>
              )}
              <span class="collection-count">{collection.data.albums.length} albums <span class="collection-arrow">&rarr;</span></span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
  </div>
</PageLayout>

<style>
  .map-hero {
    position: relative;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .map-hero__map {
    flex: 1;
    min-height: 0;
    position: relative;
  }

  .map-hero__map :global(.map-container) {
    height: 100%;
  }

  .map-hero__scroll-hint {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: map-hint-pulse 2.5s ease-in-out infinite;
    opacity: 0.35;
  }

  .map-hero__arrow {
    width: 16px;
    height: 16px;
    border-right: 1.5px solid var(--color-text-muted);
    border-bottom: 1.5px solid var(--color-text-muted);
    transform: rotate(45deg);
  }

  @keyframes map-hint-pulse {
    0%, 100% { opacity: 0.25; transform: translateX(-50%) translateY(0); }
    50% { opacity: 0.5; transform: translateX(-50%) translateY(6px); }
  }

  .work-content {
    min-height: 100dvh;
  }

  .work-header {
    padding: var(--space-xl) var(--container-padding) var(--space-md);
  }

  @media (min-width: 768px) {
    .work-header {
      display: none;
    }

    .work-grid-wrap {
      padding-top: var(--space-xl);
    }
  }

  .work-grid-wrap {
    padding-inline: var(--container-padding);
    padding-bottom: var(--space-3xl);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .collection-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-image {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
  }

  .collection-image :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .collection-card:hover .collection-image :global(.photo-img) {
    transform: scale(1.03);
  }

  .collection-info {
    padding-top: var(--space-sm);
  }

  .collection-title {
    font-size: var(--text-xl);
    font-weight: 400;
    transition: color var(--duration-fast) ease;
  }

  .collection-card:hover .collection-title {
    color: var(--color-accent);
  }

  .collection-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  .collection-count {
    font-size: var(--text-xs);
    color: var(--color-warm);
    margin-top: var(--space-xs);
    display: block;
  }

  .collection-arrow {
    display: inline-block;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--duration-fast) ease, transform var(--duration-fast) ease;
  }

  .collection-card:hover .collection-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Film-roll strip ── */
  .film-roll {
    position: relative;
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    overflow: hidden;
  }

  .film-roll__track {
    display: flex;
    gap: 3px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    padding: 3px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .film-roll__track::-webkit-scrollbar {
    display: none;
  }

  .film-roll__frame {
    flex-shrink: 0;
    width: 180px;
    height: 120px;
    position: relative;
    overflow: hidden;
    scroll-snap-align: start;
    display: block;
    cursor: pointer;
  }

  .film-roll__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-repeat: no-repeat;
    filter: brightness(0.7) saturate(0.85);
    transition: filter 200ms var(--ease-out-quart), transform 300ms var(--ease-out-quart);
  }

  .film-roll__frame:hover .film-roll__img {
    filter: brightness(1) saturate(1);
    transform: scale(1.05);
  }

  .film-roll__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fx-paper);
    background: rgba(16, 15, 15, 0.7);
    opacity: 0;
    transition: opacity 150ms;
  }

  .film-roll__frame:hover .film-roll__label {
    opacity: 1;
  }

  .film-roll__edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 90px;
    pointer-events: none;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  .film-roll__edge--left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg) 20%, transparent);
    justify-content: flex-start;
    padding-left: 10px;
  }

  .film-roll__edge--right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg) 20%, transparent);
    justify-content: flex-end;
    padding-right: 10px;
  }

  .film-roll__chevron {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-faint);
    opacity: 0.5;
    letter-spacing: -0.1em;
  }
</style>

<script>
  function initFilmRollMapLink() {
    const filmRoll = document.querySelector('[data-film-roll]');
    const mapContainer = document.querySelector<HTMLElement>('[data-map]');
    if (!filmRoll) return;

    const frames = filmRoll.querySelectorAll<HTMLElement>('.film-roll__frame');

    frames.forEach((frame) => {
      frame.addEventListener('mouseenter', () => {
        const num = frame.dataset.markerNum;
        if (!num) return;
        // Use exposed map setHovered if available (highlights regions + markers)
        if (mapContainer && (mapContainer as any).__setHovered) {
          (mapContainer as any).__setHovered(num);
        } else {
          // Fallback: just highlight markers
          document.querySelectorAll('.map-marker').forEach((el) => {
            const markerNum = (el as HTMLElement).dataset.markerNum;
            el.classList.toggle('map-marker--active', markerNum === num);
          });
        }
      });

      frame.addEventListener('mouseleave', () => {
        if (mapContainer && (mapContainer as any).__setHovered) {
          (mapContainer as any).__setHovered(null);
        } else {
          document.querySelectorAll('.map-marker').forEach((el) => {
            el.classList.remove('map-marker--active');
          });
        }
      });
    });
  }

  function initMapHeroNav() {
    const hero = document.getElementById('map-hero');
    const content = document.getElementById('work-content');
    if (!hero || !content) return;

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown') {
        // If we're still viewing the map hero, snap to content
        if (window.scrollY < hero.offsetHeight * 0.5) {
          e.preventDefault();
          content.scrollIntoView({ behavior: 'smooth' });
        }
      }
      if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        // If we're near the top of content, snap back to map
        if (window.scrollY < hero.offsetHeight * 1.5) {
          e.preventDefault();
          hero.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });

    // Click scroll hint to snap down
    const hint = hero.querySelector('.map-hero__scroll-hint');
    if (hint) {
      hint.addEventListener('click', () => {
        content.scrollIntoView({ behavior: 'smooth' });
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    initMapHeroNav();
    initFilmRollMapLink();
  });
</script>
