---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Photo from '@components/photo/Photo.astro';
import MapComponent from '@components/Map.astro';

const collections = await getCollection('photoCollections');
const allPhotos = await getCollection('photos');
const allEssayEntries = await getCollection('essays');
const essayById = new Map(allEssayEntries.map((e) => [e.id, e]));

const sortedCollections = collections.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Load country-level outlines for the world map
const countryFiles = import.meta.glob<{ default: any }>('/src/data/maps/*-country.json', { eager: true });

// Build world markers + merged regions from all collections with map data
const collectionsWithMaps = sortedCollections.filter((c) => c.data.map);
let markerNum = 0;

const worldMarkers = collectionsWithMaps.map((c) => {
  markerNum++;
  return {
    label: c.data.title,
    lng: c.data.map!.center[0],
    lat: c.data.map!.center[1],
    num: String(markerNum).padStart(2, '0'),
    target: c.data.primaryHref ?? `/work/${c.id}`,
  };
});

// Merge all region GeoJSON into one FeatureCollection with matching nums
const worldRegionFeatures: any[] = [];
collectionsWithMaps.forEach((c, i) => {
  const countryFile = `/src/data/maps/${c.id}-country.json`;
  const data = countryFiles[countryFile]?.default;
  if (!data?.features) return;
  const num = String(i + 1).padStart(2, '0');
  for (const feat of data.features) {
    worldRegionFeatures.push({
      ...feat,
      properties: { ...feat.properties, num },
    });
  }
});

const worldRegions = worldRegionFeatures.length > 0
  ? { type: 'FeatureCollection' as const, features: worldRegionFeatures }
  : undefined;

function findPhoto(id: string) {
  return allPhotos.find((p) => p.id === id);
}

// Build film-roll data: photos from albums, interleaved across collections
const allAlbums = await getCollection('albums');
type FilmPhoto = {
  url: string; width: number; height: number; lqip: string;
  collectionId: string; collectionTitle: string; markerNum: string | null;
  albumUrl: string;
};

// Gather photos per collection (up to 6 each)
const photosByCollection: FilmPhoto[][] = [];
collectionsWithMaps.forEach((c, i) => {
  const num = String(i + 1).padStart(2, '0');
  const bucket: FilmPhoto[] = [];
  for (const albumId of c.data.archiveAlbums) {
    const album = allAlbums.find((a) => a.id === albumId);
    if (!album || album.data.draft) continue;
    for (const photoId of album.data.photos.slice(0, 6)) {
      const photo = findPhoto(photoId);
      if (!photo) continue;
      bucket.push({
        url: photo.data.url, width: photo.data.width, height: photo.data.height,
        lqip: photo.data.lqip, collectionId: c.id, collectionTitle: c.data.title,
        markerNum: num, albumUrl: `/work/${c.id}/${albumId}`,
      });
    }
  }
  if (bucket.length) photosByCollection.push(bucket);
});

// Interleave round-robin: deal one from each collection in turn
const filmRollPhotos: FilmPhoto[] = [];
const maxLen = Math.max(...photosByCollection.map((b) => b.length), 0);
for (let round = 0; round < maxLen; round++) {
  for (const bucket of photosByCollection) {
    if (round < bucket.length) filmRollPhotos.push(bucket[round]);
  }
}

// ── Build story data for the dossier panel ──
type Story = {
  id: string;
  collectionId: string;
  title: string;
  description: string;
  kind: 'essay' | 'collection';
  slug: string;
  coverUrl: string;
  coverWidth: number;
  coverHeight: number;
  coverLqip: string;
  location: string;
  lng: number;
  lat: number;
  markerNum: string;
  year: string | null;
  photoCount: number;
};

const stories: Story[] = [];
collectionsWithMaps.forEach((c, i) => {
  const num = String(i + 1).padStart(2, '0');
  const lng = c.data.map!.center[0];
  const lat = c.data.map!.center[1];

  // Derive year from first album with a date
  let year: string | null = null;
  for (const albumId of c.data.archiveAlbums) {
    const album = allAlbums.find((a) => a.id === albumId);
    if (album?.data.date) {
      year = album.data.date.slice(0, 4);
      break;
    }
  }

  if (c.data.essays?.length) {
    // Each essay becomes a story entry
    for (const essayId of c.data.essays) {
      const essay = essayById.get(essayId);
      if (!essay) continue;
      const slug = essay.id.replace(new RegExp(`^${c.id}-`), '');
      const cover = essay.data.photos[essay.data.coverPhotoIndex] ?? essay.data.photos[0];
      stories.push({
        id: `${c.id}/${slug}`,
        collectionId: c.id,
        title: essay.data.title,
        description: essay.data.description || c.data.description || '',
        kind: 'essay',
        slug: `/work/${c.id}/${slug}`,
        coverUrl: cover.url,
        coverWidth: cover.width,
        coverHeight: cover.height,
        coverLqip: cover.lqip,
        location: c.data.title,
        lng, lat,
        markerNum: num,
        year,
        photoCount: essay.data.photos.length,
      });
    }
  } else {
    // Collection itself becomes a story entry
    const cover = c.data.coverPhoto ? findPhoto(c.data.coverPhoto) : null;
    stories.push({
      id: c.id,
      collectionId: c.id,
      title: c.data.title,
      description: c.data.description || '',
      kind: 'collection',
      slug: `/work/${c.id}`,
      coverUrl: cover?.data.url || '',
      coverWidth: cover?.data.width || 0,
      coverHeight: cover?.data.height || 0,
      coverLqip: cover?.data.lqip || '',
      location: c.data.title,
      lng, lat,
      markerNum: num,
      year,
      photoCount: c.data.archiveAlbums.length,
    });
  }
});

// Collect unique years for filter
const years = [...new Set(stories.map((s) => s.year).filter(Boolean))] as string[];
years.sort((a, b) => Number(b) - Number(a));

const storyCount = stories.length;
---

<PageLayout title="Work" description="Photography collections">
  {worldMarkers.length > 0 && (
    <div class="map-hero" id="map-hero">
      <!-- Year filter bar -->
      <div class="work-filter-bar">
        <span class="work-kicker">Work · Essays pinned to the world</span>
        <div class="work-year-tabs" data-year-tabs>
          <span class="work-year-label">Year</span>
          <button class="work-year-tab work-year-tab--active" data-year="all">All</button>
          {years.map((y) => (
            <button class="work-year-tab" data-year={y}>{y}</button>
          ))}
          <span class="work-story-count" data-story-count>{storyCount} stories</span>
        </div>
      </div>

      <!-- Map + Dossier grid -->
      <div class="map-hero__grid">
        <div class="map-hero__map">
          <MapComponent
            center={[10, 25]}
            zoom={1.8}
            markers={worldMarkers}
            regions={worldRegions}
            liveMarker={{ lng: -70.65, lat: -33.45, label: 'SANTIAGO, CHL' }}
            interactive={false}
            theme="default"
          />
          <!-- Coordinate readout -->
          <div class="work-coord-readout" data-coord-readout>
            <span class="work-coord-readout__text">Select a pin · {storyCount} stories</span>
          </div>
        </div>

        <!-- Story dossier panel -->
        <aside class="story-dossier" data-story-dossier>
          <div class="story-dossier__index" data-story-index>
            {stories.map((s, i) => (
              <div
                class="story-dossier__row"
                data-story-row={i}
                data-story-marker={s.markerNum}
                data-story-year={s.year || ''}
              >
                <span class="story-dossier__num">{s.markerNum}</span>
                <div class="story-dossier__row-info">
                  <span class="story-dossier__row-title">{s.title}</span>
                  <span class="story-dossier__row-meta">
                    {s.kind === 'essay' ? 'Essay' : 'Collection'} · {s.photoCount} {s.kind === 'essay' ? 'frames' : 'albums'}
                  </span>
                </div>
              </div>
            ))}
          </div>
          <div class="story-dossier__detail" data-story-detail style="display:none">
            <button class="story-dossier__back" data-story-back>&larr; Index</button>
            <div class="story-dossier__detail-inner" data-story-detail-inner>
              <!-- Populated by JS on hover/click -->
            </div>
          </div>
        </aside>

      </div>

      <!-- Mobile bottom sheet (hidden on desktop) -->
      <div class="story-sheet" data-story-sheet aria-hidden="true">
        <div class="story-sheet__backdrop" data-story-sheet-backdrop></div>
        <div class="story-sheet__drawer" data-story-sheet-drawer>
          <div class="story-sheet__handle">
            <span class="story-sheet__handle-bar"></span>
          </div>
          <div class="story-sheet__content" data-story-sheet-content>
          </div>
        </div>
      </div>

      <!-- Enhanced filmstrip (overlays bottom of grid, no layout shift) -->
      {filmRollPhotos.length > 0 && (
        <div class="film-roll film-roll--collapsed" data-film-roll>
          <div class="film-roll__status" data-film-status>
            <span class="film-roll__status-dot"></span>
            <span class="film-roll__status-text">Hero roll · select a pin to load frames</span>
          </div>
          <div class="film-roll__track" data-film-track>
            {filmRollPhotos.map((p, idx) => {
              const slug = p.url.split('/').pop() || '';
              const src = `${p.url}/${slug}-640.webp`;
              return (
                <a
                  href={p.albumUrl}
                  class="film-roll__frame"
                  data-marker-num={p.markerNum}
                  data-collection={p.collectionId}
                  data-frame-idx={idx}
                >
                  <div class="film-roll__sprocket film-roll__sprocket--top"></div>
                  <span class="film-roll__frame-num">{String(idx + 1).padStart(2, '0')}</span>
                  <img
                    src={src}
                    alt={p.collectionTitle}
                    class="film-roll__img"
                    loading="lazy"
                    decoding="async"
                    style={`background-image: url(${p.lqip}); background-size: cover;`}
                  />
                  <span class="film-roll__label">{p.collectionTitle}</span>
                  <div class="film-roll__sprocket film-roll__sprocket--bottom"></div>
                </a>
              );
            })}
            <div class="film-roll__leader">
              <span class="film-roll__leader-text">END</span>
            </div>
          </div>
          <div class="film-roll__edge film-roll__edge--left">
            <span class="film-roll__chevron">&laquo;</span>
          </div>
          <div class="film-roll__edge film-roll__edge--right">
            <span class="film-roll__chevron">&raquo;</span>
          </div>
        </div>
      )}
      <div class="map-hero__scroll-hint">
        <div class="map-hero__arrow"></div>
      </div>
    </div>
  )}

  <div class="work-content" id="work-content">
  <div class="work-header reveal">
    <h1>Work</h1>
  </div>
  <div class="work-grid-wrap">
    <div class="collections-grid stagger-children">
      {sortedCollections.map((collection) => {
        const cover = collection.data.coverPhoto ? findPhoto(collection.data.coverPhoto) : null;

        return (
          <a href={`/work/${collection.id}`} class="collection-card">
            {cover && (
              <div class="collection-image">
                <Photo
                  url={cover.data.url}
                  width={cover.data.width}
                  height={cover.data.height}
                  lqip={cover.data.lqip}
                  alt={collection.data.title}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
              </div>
            )}
            <div class="collection-info">
              <h2 class="collection-title">{collection.data.title}</h2>
              {collection.data.description && (
                <p class="collection-desc">{collection.data.description}</p>
              )}
              <span class="collection-count">{collection.data.archiveAlbums.length} albums <span class="collection-arrow">&rarr;</span></span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
  </div>

  <!-- Story data for client-side interaction -->
  <script
    type="application/json"
    data-stories
    set:html={JSON.stringify(stories)}
  />
</PageLayout>

<style>
  /* ── Map hero section ── */
  .map-hero {
    position: relative;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ── Year filter bar ── */
  .work-filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--container-padding);
    border-bottom: 1px solid var(--color-border-subtle);
    flex-shrink: 0;
  }

  .work-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .work-year-tabs {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .work-year-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-right: var(--space-xs);
  }

  .work-year-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    padding: 4px 8px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--color-text-faint);
    cursor: pointer;
    transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .work-year-tab:hover {
    color: var(--color-text-muted);
  }

  .work-year-tab--active {
    color: var(--color-text);
    border-bottom-color: var(--color-warm);
  }

  .work-story-count {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
    margin-left: var(--space-sm);
  }

  /* ── Map + Dossier grid ── */
  .map-hero__grid {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: 1fr 380px;
  }

  .map-hero__map {
    position: relative;
    min-height: 0;
  }

  .map-hero__map :global(.map-container) {
    height: 100%;
  }

  .map-hero__scroll-hint {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: map-hint-pulse 2.5s ease-in-out infinite;
    opacity: 0.35;
  }

  .map-hero__arrow {
    width: 16px;
    height: 16px;
    border-right: 1.5px solid var(--color-text-muted);
    border-bottom: 1.5px solid var(--color-text-muted);
    transform: rotate(45deg);
  }

  @keyframes map-hint-pulse {
    0%, 100% { opacity: 0.25; transform: translateX(-50%) translateY(0); }
    50% { opacity: 0.5; transform: translateX(-50%) translateY(6px); }
  }

  /* ── Coordinate readout ── */
  .work-coord-readout {
    position: absolute;
    bottom: var(--space-md);
    left: var(--space-md);
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
    pointer-events: none;
  }

  :global(.work-coord-readout--active) .work-coord-readout__text {
    color: var(--color-text-muted);
  }

  /* ── Story dossier panel ── */
  .story-dossier {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--color-border-subtle);
    background: var(--color-bg);
    overflow: hidden;
  }

  .story-dossier__index {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .story-dossier__row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
    cursor: pointer;
    transition: background var(--duration-fast) ease;
  }

  .story-dossier__row:hover {
    background: var(--color-surface);
  }

  :global(.story-dossier__row--active) {
    background: var(--color-surface) !important;
    border-left: 2px solid var(--color-warm);
  }

  :global(.story-dossier__row--hidden) {
    display: none !important;
  }

  .story-dossier__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
    flex-shrink: 0;
    width: 24px;
  }

  .story-dossier__row-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .story-dossier__row-title {
    font-size: var(--text-sm);
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .story-dossier__row-meta {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  /* Dossier detail view */
  .story-dossier__detail {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-md);
  }

  .story-dossier__back {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-warm);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    margin-bottom: var(--space-md);
  }

  .story-dossier__back:hover {
    color: var(--color-warm-light);
  }

  :global(.story-detail__cover) {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: var(--space-md);
  }

  :global(.story-detail__cover img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.story-detail__kind) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-warm);
    margin-bottom: var(--space-xs);
  }

  :global(.story-detail__title) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  :global(.story-detail__desc) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  :global(.story-detail__meta-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  :global(.story-detail__meta-item) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  :global(.story-detail__meta-label) {
    text-transform: uppercase;
    color: var(--color-text-faint);
    display: block;
    margin-bottom: 2px;
  }

  :global(.story-detail__meta-value) {
    color: var(--color-text-muted);
    font-size: 11px;
  }

  :global(.story-detail__cta) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-warm);
    text-decoration: none;
    padding: 8px 16px;
    border: 1px solid var(--color-warm);
    border-radius: 4px;
    transition: background var(--duration-fast) ease, color var(--duration-fast) ease;
  }

  :global(.story-detail__cta:hover) {
    background: var(--color-warm);
    color: var(--fx-paper);
  }

  /* ── Collections grid (preserved below map) ── */
  .work-content {
    min-height: 100dvh;
  }

  .work-header {
    padding: var(--space-xl) var(--container-padding) var(--space-md);
  }

  @media (min-width: 768px) {
    .work-header {
      display: none;
    }

    .work-grid-wrap {
      padding-top: var(--space-xl);
    }
  }

  .work-grid-wrap {
    padding-inline: var(--container-padding);
    padding-bottom: var(--space-3xl);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .collection-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-image {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
  }

  .collection-image :global(.photo-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .collection-card:hover .collection-image :global(.photo-img) {
    transform: scale(1.03);
  }

  .collection-info {
    padding-top: var(--space-sm);
  }

  .collection-title {
    font-size: var(--text-xl);
    font-weight: 400;
    transition: color var(--duration-fast) ease;
  }

  .collection-card:hover .collection-title {
    color: var(--color-accent);
  }

  .collection-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  .collection-count {
    font-size: var(--text-xs);
    color: var(--color-warm);
    margin-top: var(--space-xs);
    display: block;
  }

  .collection-arrow {
    display: inline-block;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--duration-fast) ease, transform var(--duration-fast) ease;
  }

  .collection-card:hover .collection-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Film-roll strip ── */
  .film-roll {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    border-top: 1px solid var(--color-border-subtle);
    overflow: hidden;
    background: var(--color-bg);
    transition: height 400ms var(--ease-out-quart);
  }

  .film-roll--collapsed {
    height: 48px;
  }

  .film-roll--collapsed .film-roll__track,
  .film-roll--collapsed .film-roll__edge {
    opacity: 0;
    pointer-events: none;
  }

  .film-roll--expanded {
    height: 168px;
  }

  .film-roll--expanded .film-roll__status {
    opacity: 0;
    pointer-events: none;
  }

  /* Collapsed status bar */
  .film-roll__status {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0 var(--container-padding);
    transition: opacity 200ms ease;
    z-index: 2;
  }

  .film-roll__status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
