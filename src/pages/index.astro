---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import HeroBriefing from '@components/home/HeroBriefing.astro';
import DispatchCallout from '@components/home/DispatchCallout.astro';
import ManifestSection from '@components/home/ManifestSection.astro';
import EssaysPreview from '@components/home/EssaysPreview.astro';
import ColophonTeaser from '@components/home/ColophonTeaser.astro';

const photos = await getCollection('photos');
const albums = await getCollection('albums');
const collections = await getCollection('photoCollections');

const sortedCollections = collections.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Resolve cover photo for a collection — tries coverPhoto, then first album cover, then first photo
function resolveCollectionCover(collection: typeof collections[number]) {
  if (collection.data.coverPhoto) {
    const photo = photos.find((p) => p.id === collection.data.coverPhoto);
    if (photo) return photo;
  }
  for (const albumId of collection.data.albums) {
    const album = albums.find((a) => a.id === albumId);
    if (album?.data.coverPhoto) {
      const photo = photos.find((p) => p.id === album.data.coverPhoto);
      if (photo) return photo;
    }
    if (album?.data.photos.length) {
      const photo = photos.find((p) => p.id === album.data.photos[0]);
      if (photo) return photo;
    }
  }
  return null;
}

// Resolve a landscape-oriented cover for the hero — prefers landscape (width >= height),
// falls back to any landscape photo in the collection's albums, then the regular cover
function resolveHeroCover(collection: typeof collections[number]) {
  const defaultCover = resolveCollectionCover(collection);
  if (defaultCover && defaultCover.data.width >= defaultCover.data.height) return defaultCover;

  // Search albums for a landscape photo
  for (const albumId of collection.data.albums) {
    const album = albums.find((a) => a.id === albumId);
    if (!album) continue;
    for (const photoId of album.data.photos) {
      const photo = photos.find((p) => p.id === photoId);
      if (photo && photo.data.width >= photo.data.height) return photo;
    }
  }

  // Fall back to default cover even if portrait — object-fit: cover will handle it
  return defaultCover;
}

// Count total frames in a collection's albums
function countFrames(collection: typeof collections[number]): number {
  let count = 0;
  for (const albumId of collection.data.albums) {
    const album = albums.find((a) => a.id === albumId);
    if (album) count += album.data.photos.length;
  }
  return count;
}

// Derive status from collection data
function deriveStatus(collection: typeof collections[number]): string {
  if (collection.data.albums.length === 0) return 'DRAFT';
  const hasAllDraft = collection.data.albums.every((albumId: string) => {
    const album = albums.find((a) => a.id === albumId);
    return album?.data.draft;
  });
  if (hasAllDraft) return 'EDITING';
  return 'PUBLISHED';
}

// Format coordinates for display
function fmtCoord(val: number, pos: string, neg: string): string {
  const dir = val >= 0 ? pos : neg;
  return `${Math.abs(val).toFixed(2)}° ${dir}`;
}

// ── Hero slides (landscape-preferred covers for full-bleed hero) ──
const heroSlides = sortedCollections
  .map((c) => {
    const cover = resolveHeroCover(c);
    if (!cover || !c.data.map) return null;
    const [lng, lat] = c.data.map.center;
    const exif = cover.data.exif;
    const firstAlbum = c.data.albums.length
      ? albums.find((a) => a.id === c.data.albums[0])
      : null;

    return {
      id: c.id,
      title: c.data.title,
      location: c.data.description || '',
      caption: c.data.essays?.[0]?.description || '',
      lat: fmtCoord(lat, 'N', 'S'),
      lon: fmtCoord(lng, 'E', 'W'),
      elev: '—',
      meta: exif
        ? [exif.camera?.split(' ').pop(), exif.focalLength, exif.aperture, `ISO ${exif.iso}`]
            .filter(Boolean).join(' · ')
        : `${c.data.albums.length} ALBUMS`,
      time: firstAlbum?.data.date || '',
      status: deriveStatus(c),
      url: cover.data.url,
      width: cover.data.width,
      height: cover.data.height,
      lqip: cover.data.lqip,
    };
  })
  .filter(Boolean);

// If fewer than 4 slides, supplement with featured photos
if (heroSlides.length < 4) {
  const featured = photos
    .filter((p) => p.data.featured)
    .filter((p) => !heroSlides.some((s) => s!.url === p.data.url));
  for (const p of featured.slice(0, 4 - heroSlides.length)) {
    heroSlides.push({
      id: `photo-${p.id}`,
      title: '',
      location: '',
      caption: '',
      lat: '—',
      lon: '—',
      elev: '—',
      meta: '',
      time: '',
      status: 'PUBLISHED',
      url: p.data.url,
      width: p.data.width,
      height: p.data.height,
      lqip: p.data.lqip,
    });
  }
}

// ── Dispatch (most recent collection with content) ──
const dispatchCollection = [...sortedCollections]
  .reverse()
  .find((c) => c.data.albums.length > 0 && resolveCollectionCover(c));
const dispatchCover = dispatchCollection ? resolveCollectionCover(dispatchCollection) : null;

const dispatchData = dispatchCollection && dispatchCover ? {
  title: dispatchCollection.data.title,
  href: `/work/${dispatchCollection.id}`,
  coverUrl: dispatchCover.data.url,
  coverWidth: dispatchCover.data.width,
  coverHeight: dispatchCover.data.height,
  coverLqip: dispatchCover.data.lqip,
  caption: dispatchCollection.data.description || '',
  coords: dispatchCollection.data.map
    ? `${fmtCoord(dispatchCollection.data.map.center[1], 'N', 'S')}, ${fmtCoord(dispatchCollection.data.map.center[0], 'E', 'W')}`
    : '',
  meta: dispatchCover.data.exif
    ? [dispatchCover.data.exif.camera?.split(' ').pop(), dispatchCover.data.exif.focalLength, dispatchCover.data.exif.aperture].filter(Boolean).join(' · ')
    : '',
  data: [
    { label: 'Day', value: dispatchCover.data.exif?.date || '—' },
    { label: 'Elevation', value: '—' },
    { label: 'Frames', value: String(countFrames(dispatchCollection)) },
    { label: 'Next', value: 'TBD' },
  ],
} : null;

// ── Manifest collections ──
let manifestNum = 0;
const manifestCollections = sortedCollections.map((c) => {
  manifestNum++;
  const cover = resolveCollectionCover(c);
  const [lng, lat] = c.data.map?.center || [0, 0];
  return {
    id: c.id,
    num: String(manifestNum).padStart(2, '0'),
    title: c.data.title,
    description: c.data.description || '',
    lat: c.data.map ? fmtCoord(lat, 'N', 'S') : '—',
    lon: c.data.map ? fmtCoord(lng, 'E', 'W') : '—',
    elev: '—',
    status: deriveStatus(c) === 'PUBLISHED' ? 'LIVE' : deriveStatus(c),
    frameCount: countFrames(c),
    coverUrl: cover?.data.url,
    coverWidth: cover?.data.width,
    coverHeight: cover?.data.height,
    coverLqip: cover?.data.lqip,
  };
});

// ── Essays (flatten across collections, take latest 3) ──
const allEssays: Array<{
  num: string; title: string; description: string;
  collection: string; location: string; href: string;
}> = [];
let essayNum = 0;
for (const c of sortedCollections) {
  if (!c.data.essays) continue;
  for (const essay of c.data.essays) {
    essayNum++;
    allEssays.push({
      num: String(essayNum).padStart(2, '0'),
      title: essay.title,
      description: essay.description || '',
      collection: c.data.title,
      location: c.data.title,
      href: `/work/${c.id}/${essay.slug}`,
    });
  }
}
const latestEssays = allEssays.slice(-3).reverse();
---

<PageLayout title="Corbin Heist">
  <HeroBriefing slides={heroSlides as any} dossierNum={String(sortedCollections.length).padStart(3, '0')} />
  {dispatchData && (
    <DispatchCallout {...dispatchData} />
  )}
  <ManifestSection collections={manifestCollections} totalCount={sortedCollections.length} />
  {latestEssays.length > 0 && (
    <EssaysPreview essays={latestEssays} />
  )}
  <ColophonTeaser />
</PageLayout>
