---

<EssayLayout
  title="Essay Layout Example"
  description="Kitchen sink demonstrating every essay slide type with orientation behavior."
  photos={photos}
>

  <!-- ============================================================
       1. EssaySlideText — centered, with overline
       ============================================================ -->
  <!-- Title card convention: overline uses Place · Region · Coordinates format
       e.g. "Djebel Saghro · Anti-Atlas · 31°16′N 5°59′W"
       e.g. "Ksar Tamnougalt · Draa Valley · 30°41′N 6°27′W" -->
  <EssaySlideText align="center">
    <p class="overline">EssaySlideText &middot; align="center"</p>
    <h1>Essay Layout Reference</h1>
    <p>
      Every slide type available for photo essays, shown with its component name
      and key props. Scroll or use arrow keys to advance.
    </p>
  </EssaySlideText>


  <!-- ============================================================
       2. EssaySlideFullBleed — landscape, cover (default)
       ============================================================ -->
  <EssaySlideFullBleed
    url={photos[0].url}
    width={photos[0].width}
    height={photos[0].height}
    lqip={photos[0].lqip}
    alt={photos[0].title}
    lightboxIndex={0}
    loading="eager"
    overlayPosition="bottom-left"
  >
    <h2 style="font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 400; margin-bottom: var(--space-xs);">
      EssaySlideFullBleed
    </h2>
    <p style="font-family: var(--font-mono); font-size: var(--text-xs); opacity: 0.7;">
      Landscape &middot; fit="cover" (default) &middot; overlayPosition="bottom-left"
    </p>
  </EssaySlideFullBleed>


  <!-- ============================================================
       3. EssaySlideFullBleed — portrait, contain (auto-detected)
       ============================================================ -->
  <EssaySlideFullBleed
    url={photos[14].url}
    width={photos[14].width}
    height={photos[14].height}
    lqip={photos[14].lqip}
    alt={photos[14].title}
    lightboxIndex={14}
    captionTitle="EssaySlideFullBleed — Portrait"
    captionMeta="fit=contain (auto-detected) · captionTitle · captionMeta"
  />


  <!-- ============================================================
       4. EssaySlideFullBleed — landscape with caption bar
       ============================================================ -->
  <EssaySlideFullBleed
    url={photos[10].url}
    width={photos[10].width}
    height={photos[10].height}
    lqip={photos[10].lqip}
    alt={photos[10].title}
    lightboxIndex={10}
    captionTitle="EssaySlideFullBleed — Landscape with Caption"
    captionMeta="captionTitle · captionMeta props"
  />


  <!-- ============================================================
       5. EssaySlideImageText — default (image left)
       ============================================================ -->
  <EssaySlideImageText
    url={photos[1].url}
    width={photos[1].width}
    height={photos[1].height}
    lqip={photos[1].lqip}
    alt={photos[1].title}
    lightboxIndex={1}
  >
    <h3>EssaySlideImageText</h3>
    <p>
      Default layout: image left (55%), prose right (45%). The narrative workhorse
      for pairing a single image with its story.
    </p>
    <p>
      <strong>Props shown:</strong> default (no flip). Landscape image uses
      object-fit: cover to fill the image panel.
    </p>
  </EssaySlideImageText>


  <!-- ============================================================
       6. EssaySlideImageText — flipped (image right)
       ============================================================ -->
  <EssaySlideImageText
    url={photos[8].url}
    width={photos[8].width}
    height={photos[8].height}
    lqip={photos[8].lqip}
    alt={photos[8].title}
    lightboxIndex={8}
    flip
  >
    <h3>EssaySlideImageText — Flipped</h3>
    <p>
      With <strong>flip</strong> prop: image right (45%), prose left (55%).
      Alternate flip across consecutive slides to create a zigzag reading pattern.
    </p>
  </EssaySlideImageText>


  <!-- ============================================================
       7. EssaySlideImageText — portrait image
       ============================================================ -->
  <EssaySlideImageText
    url={photos[5].url}
    width={photos[5].width}
    height={photos[5].height}
    lqip={photos[5].lqip}
    alt={photos[5].title}
    lightboxIndex={5}
  >
    <h3>EssaySlideImageText — Portrait</h3>
    <p>
      Portrait images auto-detect and use <strong>object-position: top center</strong>
      so faces and heads aren't cropped by the cover fit.
    </p>
    <p>
      The image panel still uses object-fit: cover, but the anchor point shifts
      to the top of the frame.
    </p>
  </EssaySlideImageText>


  <!-- ============================================================
       8. EssaySlideDiptych — landscape pair
       ============================================================ -->
  <EssaySlideDiptych
    photos={[
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    gap="tight"
    caption="EssaySlideDiptych — Landscape pair · gap=tight · width-filling"
  />


  <!-- ============================================================
       9. EssaySlideDiptych — portrait pair
       ============================================================ -->
  <EssaySlideDiptych
    photos={[
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
    ]}
    gap="tight"
    caption="EssaySlideDiptych — Portrait pair · gap=tight · height-constrained, centered"
  />


  <!-- ============================================================
       10. EssaySlideDiptych — gap variants
       ============================================================ -->
  <EssaySlideText align="center">
    <p class="overline">Diptych Gap Variants</p>
    <h2>gap="none" | "tight" | "normal"</h2>
    <p>
      The next three slides show the same landscape pair with each gap setting.
    </p>
  </EssaySlideText>

  <EssaySlideDiptych
    photos={[
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    gap="none"
    caption="gap=none"
  />

  <EssaySlideDiptych
    photos={[
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    gap="tight"
    caption="gap=tight (default, var(--space-sm))"
  />

  <EssaySlideDiptych
    photos={[
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    gap="normal"
    caption="gap=normal (var(--space-lg))"
  />


  <!-- ============================================================
       11. EssaySlideTriptych — landscape
       ============================================================ -->
  <EssaySlideTriptych
    photos={[
      { ...photos[11], alt: photos[11].title, lightboxIndex: 11 },
      { ...photos[12], alt: photos[12].title, lightboxIndex: 12 },
      { ...photos[13], alt: photos[13].title, lightboxIndex: 13 },
    ]}
    gap="tight"
    caption="EssaySlideTriptych — Landscape · gap=tight · width-filling"
  />


  <!-- ============================================================
       12. EssaySlideTriptych — portrait
       ============================================================ -->
  <EssaySlideTriptych
    photos={[
      { ...photos[14], alt: photos[14].title, lightboxIndex: 14 },
      { ...photos[15], alt: photos[15].title, lightboxIndex: 15 },
      { ...photos[16], alt: photos[16].title, lightboxIndex: 16 },
    ]}
    gap="tight"
    caption="EssaySlideTriptych — Portrait · gap=tight · height-constrained"
  />


  <!-- ============================================================
       13. EssaySlideMiniGallery — 3 columns
       ============================================================ -->
  <EssaySlideMiniGallery
    photos={[
      { ...photos[1], alt: photos[1].title, lightboxIndex: 1 },
      { ...photos[5], alt: photos[5].title, lightboxIndex: 5 },
      { ...photos[3], alt: photos[3].title, lightboxIndex: 3 },
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[8], alt: photos[8].title, lightboxIndex: 8 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
      { ...photos[9], alt: photos[9].title, lightboxIndex: 9 },
      { ...photos[14], alt: photos[14].title, lightboxIndex: 14 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    columns={3}
    caption="EssaySlideMiniGallery — columns=3 · 9 images · masonry layout"
  />


  <!-- ============================================================
       14. EssaySlideMiniGallery — 2 columns
       ============================================================ -->
  <EssaySlideMiniGallery
    photos={[
      { ...photos[5], alt: photos[5].title, lightboxIndex: 5 },
      { ...photos[8], alt: photos[8].title, lightboxIndex: 8 },
      { ...photos[6], alt: photos[6].title, lightboxIndex: 6 },
      { ...photos[9], alt: photos[9].title, lightboxIndex: 9 },
      { ...photos[7], alt: photos[7].title, lightboxIndex: 7 },
      { ...photos[4], alt: photos[4].title, lightboxIndex: 4 },
    ]}
    columns={2}
    caption="EssaySlideMiniGallery — columns=2 · 6 images"
  />


  <!-- ============================================================
       15. EssaySlideText — left aligned
       ============================================================ -->
  <EssaySlideText align="left">
    <p class="overline">EssaySlideText &middot; align="left"</p>
    <h2>Left-Aligned Text Slide</h2>
    <p>
      For section transitions or narrative beats where centered text feels too formal.
      The overline class gives you small mono caps for labels.
    </p>
    <p>
      Available elements: <strong>h1–h3</strong> headings, <strong>p</strong> body text,
      <strong>strong</strong> emphasis, and <strong>overline</strong> labels.
    </p>
  </EssaySlideText>


  <!-- ============================================================
       16. EssaySlideFlow — prose section
       ============================================================ -->
  <EssaySlideFlow>
    <h2>EssaySlideFlow</h2>
    <p>
      A prose-focused slide for longer narrative passages. Vertically centered within
      the viewport, max-width 680px. Snaps like every other slide.
    </p>
    <p>
      Use flow slides when the writing needs to stand alone without competing with
      an image. Supports headings, paragraphs, blockquotes, and inline photos.
    </p>
    <blockquote>
      Blockquotes render with an accent-colored left border and italic text.
      Use them for direct quotes or emphasized passages.
    </blockquote>
  </EssaySlideFlow>


  <!-- ============================================================
       17. Credits
       ============================================================ -->
  <EssaySlideText align="center">
    <p class="overline">End of Reference</p>
    <h2>Essay Layout Example</h2>
    <p>
      18 slides &middot; 7 component types &middot; orientation-aware<br />
      See <strong>docs/essay-guide.md</strong> for the full authoring guide.
    </p>
  </EssaySlideText>

</EssayLayout>
