---
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/pitch.css';
import '@styles/pitch-brand.css';
---

<BaseLayout title="HEIST.STUDIO — Wordmark Study" description="Type study for the HEIST.STUDIO wordmark." noindex={true}>
  <script is:inline>
    document.body.setAttribute('data-pitch', '');
    document.body.setAttribute('data-pitch-brand', '');
    document.documentElement.setAttribute('data-theme', 'dark');
  </script>

  <!-- ======= Cover ======= -->
  <section class="slide slide--hs-cover" id="slide-1">
    <div class="slide__inner">
      <p class="slide__overline">Wordmark Type Study</p>
      <h1 class="slide__heading slide__heading--large">HEIST.STUDIO</h1>
      <p class="slide__subtitle">Same name, different voices. Pick the one that fits.</p>
    </div>
    <div class="scroll-hint fade-in">
      <div class="scroll-hint__arrow"></div>
    </div>
  </section>

  <!-- ======= A. All Vollkorn ======= -->
  <section class="slide" id="slide-2">
    <div class="slide__inner">
      <p class="hs-section-num">A</p>
      <h2 class="slide__heading">Vollkorn</h2>
      <p class="hs-section-intro">The heading font. Warm old-style serif with texture and weight. &ldquo;Workwear, not formal dress.&rdquo;</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">A1 &middot; 600</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">A2 &middot; 400</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">A3 &middot; 700 tracked</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: 32px; letter-spacing: 0.1em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">A4 &middot; 400 neutral dot</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--fx-base-500);">.</span>STUDIO</div>
        </div>
      </div>
      <p class="hs-label" style="margin-top: var(--space-md);">Light background</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">A1</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">A2</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">A3</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: 32px; letter-spacing: 0.1em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">A4</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--fx-base-500);">.</span>STUDIO</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= B. All Plex Mono ======= -->
  <section class="slide" id="slide-3">
    <div class="slide__inner">
      <p class="hs-section-num">B</p>
      <h2 class="slide__heading">IBM Plex Mono</h2>
      <p class="hs-section-intro">The technical font. Precision as identity. Stamp-like at any weight.</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">B1 &middot; 500</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">B2 &middot; 400</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 400; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">B3 &middot; 600 tight</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 600; font-size: 28px; letter-spacing: 0.02em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">B4 &middot; 300 wide</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 300; font-size: 28px; letter-spacing: 0.14em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
      </div>
      <p class="hs-label" style="margin-top: var(--space-md);">Light background</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">B1</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">B2</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 400; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">B3</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 600; font-size: 28px; letter-spacing: 0.02em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">B4</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 300; font-size: 28px; letter-spacing: 0.14em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= C. All Plex Sans ======= -->
  <section class="slide" id="slide-4">
    <div class="slide__inner">
      <p class="hs-section-num">C</p>
      <h2 class="slide__heading">IBM Plex Sans</h2>
      <p class="hs-section-intro">The body font. Clean, open-source, no licensing dependencies.</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">C1 &middot; 500</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 500; font-size: 30px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">C2 &middot; 600</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 600; font-size: 30px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">C3 &middot; 300 wide</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 300; font-size: 30px; letter-spacing: 0.14em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">C4 &middot; 700 tight</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 700; font-size: 30px; letter-spacing: 0.02em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
      </div>
      <p class="hs-label" style="margin-top: var(--space-md);">Light background</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">C1</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 500; font-size: 30px; letter-spacing: 0.08em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">C2</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 600; font-size: 30px; letter-spacing: 0.08em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">C3</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 300; font-size: 30px; letter-spacing: 0.14em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">C4</span>
          <div style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 700; font-size: 30px; letter-spacing: 0.02em; color: var(--fx-black); line-height: 1;">HEIST<span style="color: var(--hs-bottle);">.</span>STUDIO</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= D. Mixed Type ======= -->
  <section class="slide" id="slide-5">
    <div class="slide__inner">
      <p class="hs-section-num">D</p>
      <h2 class="slide__heading">Mixed Type</h2>
      <p class="hs-section-intro">Different fonts for HEIST and STUDIO. The period bridges them.</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">D1 &middot; Vollkorn + Mono</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; color: var(--hs-forest);">.</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 20px; letter-spacing: 0.12em; color: var(--fx-base-300);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">D2 &middot; Vollkorn + Sans</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; color: var(--hs-forest);">.</span><span style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 500; font-size: 22px; letter-spacing: 0.1em; color: var(--fx-base-300);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">D3 &middot; Same size mixed</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 28px; letter-spacing: 0.04em; color: var(--fx-base-100);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 28px; color: var(--hs-forest);">.</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.04em; color: var(--fx-base-100);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">D4 &middot; Mono + Vollkorn</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.06em; color: var(--fx-base-100);">HEIST</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; color: var(--hs-forest);">.</span><span style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.02em; color: var(--fx-base-300);">STUDIO</span></div>
        </div>
      </div>
      <p class="hs-label" style="margin-top: var(--space-md);">Light background</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">D1</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-black);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; color: var(--hs-bottle);">.</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 20px; letter-spacing: 0.12em; color: var(--fx-base-600);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">D2</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-black);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; color: var(--hs-bottle);">.</span><span style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 500; font-size: 22px; letter-spacing: 0.1em; color: var(--fx-base-600);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">D3</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 28px; letter-spacing: 0.04em; color: var(--fx-black);">HEIST</span><span style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 28px; color: var(--hs-bottle);">.</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.04em; color: var(--fx-black);">STUDIO</span></div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--light">
          <span class="hs-mark-cell__label">D4</span>
          <div style="display: inline-flex; align-items: baseline; line-height: 1;"><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.06em; color: var(--fx-black);">HEIST</span><span style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; color: var(--hs-bottle);">.</span><span style="font-family: 'Vollkorn', serif; font-weight: 400; font-size: 32px; letter-spacing: 0.02em; color: var(--fx-base-600);">STUDIO</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= E. Dot Treatments ======= -->
  <section class="slide" id="slide-6">
    <div class="slide__inner">
      <p class="hs-section-num">E</p>
      <h2 class="slide__heading">Dot Treatments</h2>
      <p class="hs-section-intro">The period is the only design element. How much should it say?</p>
      <p class="hs-label">Using Plex Mono 500 as base</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E1 &middot; Forest green</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E2 &middot; Rust</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-rust);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E3 &middot; Muted</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--fx-base-500);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E4 &middot; Same as text</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 28px; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1;">HEIST.STUDIO</div>
        </div>
      </div>
      <p class="hs-label" style="margin-top: var(--space-md);">Using Vollkorn 600 as base</p>
      <div class="hs-mark-grid hs-mark-grid--4">
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E5 &middot; Forest green</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E6 &middot; Rust</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--hs-rust);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E7 &middot; Muted</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST<span style="color: var(--fx-base-500);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark">
          <span class="hs-mark-cell__label">E8 &middot; Same as text</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; font-size: 32px; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1;">HEIST.STUDIO</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= F. Scale ======= -->
  <section class="slide" id="slide-7">
    <div class="slide__inner">
      <p class="hs-section-num">F</p>
      <h2 class="slide__heading">Scale Test</h2>
      <p class="hs-section-intro">How each family reads at small sizes. Watermark, footer, metadata.</p>
      <p class="hs-label">Large &rarr; Small</p>
      <div class="hs-mark-grid hs-mark-grid--2">
        <div class="hs-mark-cell hs-mark-cell--dark" style="align-items: flex-start; padding: 32px; gap: 24px; min-height: 280px;">
          <span class="hs-mark-cell__label">Vollkorn 600</span>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1; font-size: 48px;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1; font-size: 28px;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1; font-size: 16px;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
          <div style="font-family: 'Vollkorn', serif; font-weight: 600; letter-spacing: 0.04em; color: var(--fx-base-100); line-height: 1; font-size: 11px;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
        </div>
        <div class="hs-mark-cell hs-mark-cell--dark" style="align-items: flex-start; padding: 32px; gap: 24px; min-height: 280px;">
          <span class="hs-mark-cell__label">Plex Mono 500</span>
          <div style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; letter-spacing: 0.08em; color: var(--fx-base-100); line-height: 1; font-size: 48px;">HEIST<span style="color: var(--hs-forest);">.</span>STUDIO</div>
