---
import ArchivePitchLayout from '@layouts/ArchivePitchLayout.astro';
---

<ArchivePitchLayout
  title="The Korman Archive — Brand Identity"
  description="Brand identity reference for The Korman Archive heritage documentation project."
>

  <!-- ======= 1. Cover ======= -->
  <section class="slide slide--ka-hero" id="slide-1">
    <div class="slide__inner">
      <div class="ka-lockup-primary ka-lockup-primary--cover">
        <span class="ka-lockup-primary__the">The</span>
        <span class="ka-lockup-primary__korman">Korman</span>
        <span class="ka-lockup-primary__archive">Archive</span>
      </div>
      <div class="ka-hero-meta">Brand Identity Reference &middot; March 2026</div>
    </div>
    <div class="scroll-hint fade-in">
      <div class="scroll-hint__arrow"></div>
    </div>
  </section>

  <!-- ======= 2. 01 Positioning — Is / Is Not ======= -->
  <section class="slide" id="slide-2">
    <div class="slide__inner">
      <p class="ka-section-num">01</p>
      <h2 class="slide__heading">Positioning</h2>
      <div class="ka-two-col">
        <div class="ka-position-card ka-position-card--is">
          <div class="ka-position-card__label">The Archive Is</div>
          <ul class="ka-position-card__list">
            <li>A heritage documentation project capturing institutional knowledge</li>
            <li>The technical philosophy, competition history, and craft of Korman Autoworks</li>
            <li>A bounded sub-identity within the larger Korman brand system</li>
            <li>Warm, documentary, and precise in tone</li>
            <li>Built for researchers, enthusiasts, and the Korman family itself</li>
          </ul>
        </div>
        <div class="ka-position-card ka-position-card--isnot">
          <div class="ka-position-card__label">The Archive Is Not</div>
          <ul class="ka-position-card__list">
            <li>A marketing channel or sales funnel</li>
            <li>A replacement for the V2 product brand (Amber Theorem)</li>
            <li>A nostalgia exercise or museum piece</li>
            <li>Consumer-facing content designed for broad reach</li>
            <li>A separate company or independent entity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 3. 01 Positioning — Origin Story ======= -->
  <section class="slide" id="slide-3">
    <div class="slide__inner">
      <p class="ka-section-num">01</p>
      <h2 class="slide__heading">Origin</h2>
      <p class="ka-section-intro">The Korman Archive exists because some things are too important to live only in the memories of the people who built them. Ray Korman&rsquo;s technical philosophy&mdash;the specific way he approached engine tolerances, the reasoning behind suspension geometry choices, the competition strategies that produced two wins at the 24 Hours of Watkins Glen&mdash;these are institutional knowledge that disappears when it isn&rsquo;t deliberately captured.</p>
      <p class="ka-section-intro">The Archive is a bounded sub-identity: warm where the V2 product brand is sharp, documentary where V2 is assertive. It shares Korman&rsquo;s DNA but speaks in a quieter register. Where Amber Theorem says &ldquo;The Ultimate Driving Machine. Finished,&rdquo; the Archive says &ldquo;Here&rsquo;s exactly how they finished it, and why.&rdquo;</p>
      <p class="ka-section-intro">The design system reflects this difference at every level&mdash;typography, color, marks, voice. What follows is the complete brand reference.</p>
    </div>
  </section>

  <!-- ======= 4. 02 Marks — Primary Lockup ======= -->
  <section class="slide" id="slide-4">
    <div class="slide__inner">
      <p class="ka-section-num">02</p>
      <h2 class="slide__heading">Primary Lockup</h2>
      <p class="ka-label">Stacked mark &mdash; 4 background variants</p>
      <div class="ka-mark-grid ka-mark-grid--4">
        <div class="ka-mark-cell ka-mark-cell--dark">
          <span class="ka-mark-cell__label">Dark</span>
          <div class="ka-lockup-primary">
            <span class="ka-lockup-primary__the">The</span>
            <span class="ka-lockup-primary__korman">Korman</span>
            <span class="ka-lockup-primary__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--light">
          <span class="ka-mark-cell__label">Light</span>
          <div class="ka-lockup-primary">
            <span class="ka-lockup-primary__the">The</span>
            <span class="ka-lockup-primary__korman">Korman</span>
            <span class="ka-lockup-primary__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--warm">
          <span class="ka-mark-cell__label">Warm</span>
          <div class="ka-lockup-primary">
            <span class="ka-lockup-primary__the">The</span>
            <span class="ka-lockup-primary__korman">Korman</span>
            <span class="ka-lockup-primary__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--mid">
          <span class="ka-mark-cell__label">Mid</span>
          <div class="ka-lockup-primary">
            <span class="ka-lockup-primary__the">The</span>
            <span class="ka-lockup-primary__korman">Korman</span>
            <span class="ka-lockup-primary__archive">Archive</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 5. 02 Marks — Inline Lockup ======= -->
  <section class="slide" id="slide-5">
    <div class="slide__inner">
      <p class="ka-section-num">02</p>
      <h2 class="slide__heading">Inline Lockup</h2>
      <p class="ka-label">Horizontal mark &mdash; 4 background variants</p>
      <div class="ka-mark-grid ka-mark-grid--4">
        <div class="ka-mark-cell ka-mark-cell--dark">
          <span class="ka-mark-cell__label">Dark</span>
          <div class="ka-lockup-inline">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--light">
          <span class="ka-mark-cell__label">Light</span>
          <div class="ka-lockup-inline">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--warm">
          <span class="ka-mark-cell__label">Warm</span>
          <div class="ka-lockup-inline">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--mid">
          <span class="ka-mark-cell__label">Mid</span>
          <div class="ka-lockup-inline">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
      </div>
      <p class="ka-label" style="margin-top: var(--space-md);">Small-scale use</p>
      <div class="ka-mark-grid ka-mark-grid--2">
        <div class="ka-mark-cell ka-mark-cell--dark" style="min-height: 120px; padding: 20px;">
          <div class="ka-lockup-inline ka-lockup-inline--sm">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--warm" style="min-height: 120px; padding: 20px;">
          <div class="ka-lockup-inline ka-lockup-inline--sm">
            <span class="ka-lockup-inline__korman">Korman</span>
            <span class="ka-lockup-inline__sep">|</span>
            <span class="ka-lockup-inline__archive">Archive</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 6. 02 Marks — Document Stamp ======= -->
  <section class="slide" id="slide-6">
    <div class="slide__inner">
      <p class="ka-section-num">02</p>
      <h2 class="slide__heading">Document Stamp</h2>
      <p class="ka-label">Standard and extended formats</p>
      <div class="ka-mark-grid ka-mark-grid--4">
        <div class="ka-mark-cell ka-mark-cell--dark">
          <span class="ka-mark-cell__label">Standard</span>
          <div class="ka-stamp">
            <span class="ka-stamp__line1">Korman Archive</span>
            <span class="ka-stamp__line2">Heritage Document</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--dark">
          <span class="ka-mark-cell__label">Extended</span>
          <div class="ka-stamp ka-stamp--extended">
            <span class="ka-stamp__line1">Korman Archive</span>
            <span class="ka-stamp__line2">Heritage Document</span>
            <span class="ka-stamp__catalog">KA-2026-0047</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--light">
          <span class="ka-mark-cell__label">Light bg</span>
          <div class="ka-stamp">
            <span class="ka-stamp__line1">Korman Archive</span>
            <span class="ka-stamp__line2">Heritage Document</span>
          </div>
        </div>
        <div class="ka-mark-cell ka-mark-cell--warm">
          <span class="ka-mark-cell__label">Warm bg</span>
          <div class="ka-stamp">
            <span class="ka-stamp__line1">Korman Archive</span>
            <span class="ka-stamp__line2">Heritage Document</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 7. 03 Color — Flexoki Base ======= -->
  <section class="slide" id="slide-7">
    <div class="slide__inner">
      <p class="ka-section-num">03</p>
      <h2 class="slide__heading">Color &mdash; Flexoki Base</h2>
      <p class="ka-label">Neutral foundation &mdash; 11 swatches</p>
      <div class="ka-swatch-row">
        <div class="ka-swatch ka-swatch--lt" style="background: #100F0F;">
          <span class="ka-swatch__name">Black</span>
          <span class="ka-swatch__hex">#100F0F</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #1C1B1A;">
          <span class="ka-swatch__name">900</span>
          <span class="ka-swatch__hex">#1C1B1A</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #282726;">
          <span class="ka-swatch__name">850</span>
          <span class="ka-swatch__hex">#282726</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #343331;">
          <span class="ka-swatch__name">800</span>
          <span class="ka-swatch__hex">#343331</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #403E3C;">
          <span class="ka-swatch__name">700</span>
          <span class="ka-swatch__hex">#403E3C</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #575653;">
          <span class="ka-swatch__name">600</span>
          <span class="ka-swatch__hex">#575653</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #6F6E69;">
          <span class="ka-swatch__name">500</span>
          <span class="ka-swatch__hex">#6F6E69</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #B7B5AC;">
          <span class="ka-swatch__name">300</span>
          <span class="ka-swatch__hex">#B7B5AC</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #CECDC3;">
          <span class="ka-swatch__name">200</span>
          <span class="ka-swatch__hex">#CECDC3</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #E6E4D9;">
          <span class="ka-swatch__name">100</span>
          <span class="ka-swatch__hex">#E6E4D9</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #FFFCF0;">
          <span class="ka-swatch__name">Paper</span>
          <span class="ka-swatch__hex">#FFFCF0</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 8. 03 Color — Warm Scale + Exclusions ======= -->
  <section class="slide" id="slide-8">
    <div class="slide__inner">
      <p class="ka-section-num">03</p>
      <h2 class="slide__heading">Color &mdash; Warm Scale</h2>
      <p class="ka-label">Archive warm palette &mdash; Heist-derived</p>
      <div class="ka-swatch-row">
        <div class="ka-swatch ka-swatch--lt" style="background: #4A2E1B;">
          <span class="ka-swatch__name">Walnut</span>
          <span class="ka-swatch__hex">#4A2E1B</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #6B4226;">
          <span class="ka-swatch__name">Leather</span>
          <span class="ka-swatch__hex">#6B4226</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #8B5E3C;">
          <span class="ka-swatch__name">Tobacco</span>
          <span class="ka-swatch__hex">#8B5E3C</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #A67B5B;">
          <span class="ka-swatch__name">Saddle</span>
          <span class="ka-swatch__hex">#A67B5B</span>
        </div>
        <div class="ka-swatch ka-swatch--lt" style="background: #C4956A;">
          <span class="ka-swatch__name">Honey</span>
          <span class="ka-swatch__hex">#C4956A</span>
        </div>
        <div class="ka-swatch ka-swatch--dk" style="background: #D4A373;">
          <span class="ka-swatch__name">Clay</span>
          <span class="ka-swatch__hex">#D4A373</span>
        </div>
      </div>
      <p class="ka-label" style="margin-top: var(--space-md);">Exclusion zone &mdash; reserved for V2</p>
      <div class="ka-swatch-row">
        <div class="ka-swatch ka-swatch--lt ka-exclusion" style="background: #0066B1;">
          <span class="ka-swatch__name">Blue</span>
          <span class="ka-swatch__hex">#0066B1</span>
        </div>
        <div class="ka-swatch ka-swatch--lt ka-exclusion" style="background: #2B115A;">
          <span class="ka-swatch__name">Violet</span>
          <span class="ka-swatch__hex">#2B115A</span>
        </div>
        <div class="ka-swatch ka-swatch--lt ka-exclusion" style="background: #C62828;">
          <span class="ka-swatch__name">Red</span>
          <span class="ka-swatch__hex">#C62828</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 9. 04 Typography — Specimens ======= -->
  <section class="slide" id="slide-9">
    <div class="slide__inner">
      <p class="ka-section-num">04</p>
      <h2 class="slide__heading">Typography</h2>
      <div class="ka-specimen">
        <div class="ka-specimen__label">Display &mdash; Section Headings</div>
        <div class="ka-specimen__sample" style="font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 32px; letter-spacing: 0.1em; text-transform: uppercase;">
          Engine Build Documentation
        </div>
        <div class="ka-specimen__meta">Barlow Condensed 900 &middot; Uppercase &middot; 0.1em tracking</div>
      </div>
      <div class="ka-specimen">
        <div class="ka-specimen__label">Technical &mdash; Headings, Metadata</div>
        <div class="ka-specimen__sample" style="font-family: 'IBM Plex Mono', monospace; font-weight: 400; font-size: 16px; letter-spacing: 0.02em;">
          S14 Engine — Bore 95mm × Stroke 87mm — Displacement 2,467cc
        </div>
        <div class="ka-specimen__meta">IBM Plex Mono 400 &middot; Sentence case &middot; 0.02em tracking</div>
      </div>
      <div class="ka-specimen">
        <div class="ka-specimen__label">Caption &mdash; Labels, Identifiers</div>
        <div class="ka-specimen__sample" style="font-family: 'IBM Plex Mono', monospace; font-weight: 300; font-size: 11px; letter-spacing: 0.06em; color: var(--fx-base-500);">
          Photograph by Corbin Millet &middot; Greensboro, NC &middot; February 2026
        </div>
        <div class="ka-specimen__meta">IBM Plex Mono 300 &middot; 11px &middot; 0.06em tracking</div>
      </div>
      <div class="ka-specimen">
        <div class="ka-specimen__label">Body &mdash; Prose, Descriptions</div>
        <div class="ka-specimen__sample" style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 300; font-size: 15px; line-height: 1.7; color: var(--fx-base-300);">
          The valve adjustment procedure Ray developed for the M10 engine became a shop standard that persisted across three decades. It wasn&rsquo;t written down until 2024.
        </div>
        <div class="ka-specimen__meta">IBM Plex Sans 300 &middot; 15px &middot; 1.7 line-height</div>
      </div>
      <div class="ka-specimen">
        <div class="ka-specimen__label">Speaker Label &mdash; Oral History Attribution</div>
        <div class="ka-specimen__sample" style="font-family: 'IBM Plex Mono', monospace; font-weight: 500; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ka-honey);">
          Ray Korman &middot; Founder
        </div>
        <div class="ka-specimen__meta">IBM Plex Mono 500 &middot; Uppercase &middot; 0.08em tracking &middot; Honey accent</div>
      </div>
    </div>
  </section>

  <!-- ======= 10. 04 Typography — Hierarchy in Context ======= -->
  <section class="slide" id="slide-10">
    <div class="slide__inner">
      <p class="ka-section-num">04</p>
      <h2 class="slide__heading">Hierarchy in Context</h2>
      <div class="ka-hierarchy-demo">
        <div class="ka-hierarchy-demo__section">Engine Build #028</div>
        <div class="ka-hierarchy-demo__technical">S14/23 — 2.5L Stroker, Stage III Specification</div>
        <div class="ka-hierarchy-demo__body">
          The bore-and-stroke combination that would eventually define Korman&rsquo;s Stage III package started as a competition experiment in 1986. Ray wanted to push the S14 past its factory displacement ceiling without sacrificing the rev ceiling that made the engine competitive in IMSA trim. The result&mdash;95mm bore, 87mm stroke&mdash;predated BMW Motorsport&rsquo;s own Sport Evolution by three years.
        </div>
        <div class="ka-hierarchy-demo__caption">Documented from shop records and oral history, January 2026.</div>
        <div class="ka-hierarchy-demo__speaker">Ray Korman &middot; Founder</div>
      </div>
    </div>
  </section>

  <!-- ======= 11. 05 Voice — Do/Don't ======= -->
  <section class="slide" id="slide-11">
    <div class="slide__inner">
      <p class="ka-section-num">05</p>
      <h2 class="slide__heading">Voice &amp; Tone</h2>
      <div class="ka-voice-grid">
        <div class="ka-voice ka-voice--do">
          <div class="ka-voice__label">Do</div>
          <div class="ka-voice__text">&ldquo;The Stage III package produces 245 horsepower at 7,400 rpm on Korman&rsquo;s dyno, measured at the flywheel with a 10.5:1 compression ratio.&rdquo;</div>
        </div>
        <div class="ka-voice ka-voice--dont">
          <div class="ka-voice__label">Don&rsquo;t</div>
          <div class="ka-voice__text">&ldquo;This insane build pushes out an incredible 245 horses, making it one of the most powerful S14s ever built!&rdquo;</div>
        </div>
        <div class="ka-voice ka-voice--do">
          <div class="ka-voice__label">Do</div>
          <div class="ka-voice__text">&ldquo;Ray adjusted valve clearances by feel before verifying with feeler gauges&mdash;a method he developed during the 1982 Watkins Glen campaign.&rdquo;</div>
        </div>
        <div class="ka-voice ka-voice--dont">
          <div class="ka-voice__label">Don&rsquo;t</div>
          <div class="ka-voice__text">&ldquo;In the good old days, master mechanics like Ray didn&rsquo;t need fancy tools&mdash;they just knew.&rdquo;</div>
        </div>
        <div class="ka-voice ka-voice--do">
          <div class="ka-voice__label">Do</div>
          <div class="ka-voice__text">&ldquo;The Archive preserves these methods so they can be studied, taught, and applied to future builds.&rdquo;</div>
        </div>
        <div class="ka-voice ka-voice--dont">
          <div class="ka-voice__label">Don&rsquo;t</div>
          <div class="ka-voice__text">&ldquo;We&rsquo;re saving the dying art of real craftsmanship before it&rsquo;s lost forever.&rdquo;</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 12. 05 Voice — The Rule ======= -->
  <section class="slide" id="slide-12">
    <div class="slide__inner">
      <div class="ka-rule-callout">
        <div class="ka-rule-callout__label">The Rule</div>
        <p class="ka-rule-callout__text">
          Every sentence should pass the <em>dyno sheet test</em>: could you back this claim with a measurement, a date, a name, or a photograph? If not, rewrite it until you can.
        </p>
      </div>
    </div>
  </section>

  <!-- ======= 13. 06 Applications — Scanned Docs, Photos, Transcripts ======= -->
  <section class="slide" id="slide-13">
    <div class="slide__inner">
      <p class="ka-section-num">06</p>
      <h2 class="slide__heading">Applications</h2>
      <div class="ka-card-grid ka-card-grid--3">
        <div class="ka-app-card">
          <div class="ka-app-card__mockup">
            <span class="ka-app-card__mockup-text">Scanned document</span>
          </div>
          <div class="ka-app-card__body">
            <div class="ka-app-card__title">Technical Documents</div>
            <div class="ka-app-card__desc">Engine build sheets, dyno printouts, parts lists, and shop notes. Scanned at high resolution with Archive stamp and catalog number applied to each document.</div>
          </div>
        </div>
        <div class="ka-app-card">
          <div class="ka-app-card__mockup">
            <span class="ka-app-card__mockup-text">Photograph</span>
          </div>
          <div class="ka-app-card__body">
            <div class="ka-app-card__title">Photography</div>
            <div class="ka-app-card__desc">Documentary photographs of builds, tools, shop spaces, and racing history. Captioned with Plex Mono, warm-toned treatment consistent with the Archive palette.</div>
          </div>
        </div>
        <div class="ka-app-card">
          <div class="ka-app-card__mockup">
            <span class="ka-app-card__mockup-text">Transcript</span>
          </div>
          <div class="ka-app-card__body">
            <div class="ka-app-card__title">Oral Histories</div>
            <div class="ka-app-card__desc">Recorded conversations with Ray, family members, and long-time customers. Transcribed with speaker labels, timestamps, and contextual notes.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 14. 06 Applications — Catalog + Video ======= -->
  <section class="slide" id="slide-14">
    <div class="slide__inner">
      <p class="ka-section-num">06</p>
      <h2 class="slide__heading">Applications</h2>
      <p class="ka-label">Additional contexts</p>
      <div class="ka-card-grid ka-card-grid--2">
        <div class="ka-app-card">
          <div class="ka-app-card__mockup">
            <span class="ka-app-card__mockup-text">Catalog entry</span>
          </div>
          <div class="ka-app-card__body">
            <div class="ka-app-card__title">Catalog Entries</div>
            <div class="ka-app-card__desc">Structured records for each documented build, part, or competition result. Catalog numbers follow the KA-YYYY-NNNN format. Cross-referenced with related documents and photographs.</div>
          </div>
        </div>
        <div class="ka-app-card">
          <div class="ka-app-card__mockup">
            <span class="ka-app-card__mockup-text">Video title card</span>
          </div>
          <div class="ka-app-card__body">
            <div class="ka-app-card__title">Video Title Cards</div>
            <div class="ka-app-card__desc">Opening frames for documentary video segments. Archive lockup on dark background, followed by subject identifier in Plex Mono. No motion graphics&mdash;still frames with cuts.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 15. 07 Principles ======= -->
  <section class="slide" id="slide-15">
    <div class="slide__inner">
      <p class="ka-section-num">07</p>
      <h2 class="slide__heading">Principles</h2>
      <div class="ka-card-grid ka-card-grid--2">
        <div class="ka-card">
          <div class="ka-card__title">Precision is warmth</div>
          <div class="ka-card__text">Getting the details right is how you show respect for the subject. Exact measurements, correct dates, proper attribution&mdash;these aren&rsquo;t cold, they&rsquo;re caring.</div>
        </div>
        <div class="ka-card">
          <div class="ka-card__title">Facts are the story</div>
          <div class="ka-card__text">The Archive doesn&rsquo;t need narrative embellishment. A dyno sheet from 1986 that shows 245 horsepower tells its own story. Present the evidence and let it speak.</div>
        </div>
        <div class="ka-card">
          <div class="ka-card__title">Warm, not nostalgic</div>
          <div class="ka-card__text">The tone is present-tense and forward-looking. This isn&rsquo;t &ldquo;the way things used to be&rdquo;&mdash;it&rsquo;s &ldquo;the way things were done, and why it still matters.&rdquo;</div>
        </div>
        <div class="ka-card">
          <div class="ka-card__title">Seed the future</div>
          <div class="ka-card__text">Every document captured today is a resource for someone in the future. Build the Archive like someone will depend on it in thirty years, because they will.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= 16. 08 V2 Relationship — Diagram ======= -->
