{
  "name": "photography-portfolio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm validate:content && astro check && astro build && pnpm check:bundle",
    "preview": "astro preview",
    "preview:start": "tsx scripts/preview.ts start",
    "preview:list": "tsx scripts/preview.ts list",
    "preview:stop": "tsx scripts/preview.ts stop",
    "preview:stop-all": "tsx scripts/preview.ts stop-all",
    "preview:clean": "tsx scripts/preview.ts clean",
    "astro": "astro",
    "process-images": "tsx scripts/process-images.ts",
    "upload-images": "tsx scripts/upload-to-spaces.ts",
    "generate-yaml": "tsx scripts/generate-photo-yaml.ts",
    "fetch-rss": "tsx scripts/fetch-rss.ts",
    "check:bundle": "tsx scripts/check-build-budget.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:built": "playwright test",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.3",
    "@aws-sdk/client-s3": "^3.985.0",
    "astro": "^5.17.1",
    "exif-reader": "^2.0.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "maplibre-gl": "^5.21.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "web-vitals": "^5.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.1",
    "happy-dom": "^20.5.3",
    "serve": "^14.2.4",
    "vitest": "^4.0.18"
  }
}
